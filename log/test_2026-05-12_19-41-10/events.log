[11.461419] (control) StdoutLine: {'line': b'3: -        if (!detectGatePosts(node, left_angle, right_angle, left_dist, right_dist, gate_width)) {\n'}
[11.461458] (control) StdoutLine: {'line': b'3: -            RCLCPP_WARN_THROTTLE(node->get_logger(), *node->get_clock(), 2000,\n'}
[11.461498] (control) StdoutLine: {'line': b'3: -                               "Gate Ga kedetek, stopping movement...");\n'}
[11.461539] (control) StdoutLine: {'line': b'3: -            \n'}
[11.461581] (control) StdoutLine: {'line': b'3: -            // Stop the drone if gate is lost (global frame)\n'}
[11.461621] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.461662] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.stamp = node->now();\n'}
