[11.465042] (control) StdoutLine: {'line': b'3: -            // Global frame transformation:\n'}
[11.465081] (control) StdoutLine: {'line': b'3: -            // vx_global = vx_body * cos(yaw) - vy_body * sin(yaw)\n'}
[11.465120] (control) StdoutLine: {'line': b'3: -            // vy_global = vx_body * sin(yaw) + vy_body * cos(yaw)\n'}
