[11.483144] (control) StdoutLine: {'line': b'3: -                target_velocity_z = 0.3 * altitude_error; // Gentle proportional control\n'}
[11.483183] (control) StdoutLine: {'line': b'3: -                target_velocity_z = std::max(-0.2f, std::min(0.2f, target_velocity_z)); // Limit to \xc2\xb10.2 m/s\n'}
[11.483236] (control) StdoutLine: {'line': b'3: -            }\n'}
[11.483279] (control) StdoutLine: {'line': b'3: -            \n'}
