[11.482418] (control) StdoutLine: {'line': b'3: -            float current_yaw = getHeading(current_pose.pose.orientation);\n'}
[11.482462] (control) StdoutLine: {'line': b'3: -            \n'}
[11.482503] (control) StdoutLine: {'line': b'3: -            // Transform velocity from body frame to global frame\n'}
[11.482543] (control) StdoutLine: {'line': b'3: -            // Global frame transformation:\n'}
[11.482583] (control) StdoutLine: {'line': b'3: -            // vx_global = vx_body * cos(yaw) - vy_body * sin(yaw)\n'}
[11.482622] (control) StdoutLine: {'line': b'3: -            // vy_global = vx_body * sin(yaw) + vy_body * cos(yaw)\n'}
