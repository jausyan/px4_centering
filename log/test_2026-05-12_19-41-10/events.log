[11.428486] (control) StdoutLine: {'line': b'3: +    float center_y = (left_y + right_y) / 2.0;\n'}
[11.428525] (control) StdoutLine: {'line': b'3: +\n'}
[11.428565] (control) StdoutLine: {'line': b'3: +    // The offset we need to move is just the Y component (lateral offset)\n'}
[11.428606] (control) StdoutLine: {'line': b'3: +    // Positive center_y means gate center is to the LEFT, so we need to strafe LEFT\n'}
[11.428648] (control) StdoutLine: {'line': b'3: +    // Negative center_y means gate center is to the RIGHT, so we need to strafe RIGHT\n'}
[11.428689] (control) StdoutLine: {'line': b'3: +    float lateral_offset = center_y;\n'}
[11.428728] (control) StdoutLine: {'line': b'3: +\n'}
[11.428769] (control) StdoutLine: {'line': b'3: +    RCLCPP_INFO(\n'}
[11.428808] (control) StdoutLine: {'line': b'3: +      node->get_logger(),\n'}
[11.428848] (control) StdoutLine: {'line': b'3: +      "offset center gate: %.3f m (forward: %.2f m, lateral: %.2f m)",\n'}
[11.428889] (control) StdoutLine: {'line': b'3: +      lateral_offset, center_x, center_y);\n'}
[11.428929] (control) StdoutLine: {'line': b'3: +\n'}
[11.428971] (control) StdoutLine: {'line': b"3: +    // Check if we're centered\n"}
[11.429012] (control) StdoutLine: {'line': b'3: +    if (fabs(lateral_offset) < tolerance) {\n'}
[11.429054] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count++;\n'}
[11.429094] (control) StdoutLine: {'line': b'3: +      RCLCPP_INFO(\n'}
[11.429134] (control) StdoutLine: {'line': b'3: +        node->get_logger(),\n'}
[11.429176] (control) StdoutLine: {'line': b'3: +        "Centered! (%.3f m offset, %d/%d consecutive)",\n'}
[11.429222] (control) StdoutLine: {'line': b'3: +        lateral_offset, consecutive_centered_count, required_consecutive);\n'}
[11.429270] (control) StdoutLine: {'line': b'3: +\n'}
[11.429311] (control) StdoutLine: {'line': b'3: +      if (consecutive_centered_count >= required_consecutive) {\n'}
[11.429355] (control) StdoutLine: {'line': b'3: +        RCLCPP_INFO(node->get_logger(), "Gate centering successful!");\n'}
[11.429397] (control) StdoutLine: {'line': b'3: +        status = true;\n'}
[11.429439] (control) StdoutLine: {'line': b'3: +        posee = node->getCurrentLocalPose();\n'}
[11.429478] (control) StdoutLine: {'line': b'3: +        return;\n'}
[11.429519] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.429560] (control) StdoutLine: {'line': b'3: +    } else {\n'}
[11.429601] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count = 0;\n'}
[11.429644] (control) StdoutLine: {'line': b'3: +\n'}
[11.429685] (control) StdoutLine: {'line': b'3: +      // Calculate strafe distance (limit to prevent overshooting)\n'}
[11.429731] (control) StdoutLine: {'line': b'3: +      float max_strafe_per_iteration = 0.3;       // Maximum 30cm per iteration\n'}
[11.429773] (control) StdoutLine: {'line': b'3: +      float strafe_distance = lateral_offset;\n'}
[11.429812] (control) StdoutLine: {'line': b'3: +\n'}
[11.429853] (control) StdoutLine: {'line': b'3: +      if (fabs(strafe_distance) > max_strafe_per_iteration) {\n'}
[11.429894] (control) StdoutLine: {'line': b'3: +        strafe_distance =\n'}
[11.429935] (control) StdoutLine: {'line': b'3: +          (strafe_distance > 0) ? max_strafe_per_iteration : -max_strafe_per_iteration;\n'}
[11.429977] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.430019] (control) StdoutLine: {'line': b'3: +\n'}
[11.430061] (control) StdoutLine: {'line': b'3: +      // Strafe to center\n'}
[11.430102] (control) StdoutLine: {'line': b'3: +      // Positive offset = gate is to the left, strafe left (positive y)\n'}
[11.430144] (control) StdoutLine: {'line': b'3: +      // Negative offset = gate is to the right, strafe right (negative y)\n'}
[11.430187] (control) StdoutLine: {'line': b'3: +      RCLCPP_INFO(node->get_logger(), "Strafing %.3f m to center...", strafe_distance);\n'}
[11.430240] (control) StdoutLine: {'line': b'3: +\n'}
[11.430284] (control) StdoutLine: {'line': b'3: +      executeLocalWaypointMove(node, rate, posee, 0.0, strafe_distance, 0.0, 0.0, 0.1);\n'}
[11.430324] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.430366] (control) StdoutLine: {'line': b'3: +\n'}
[11.430407] (control) StdoutLine: {'line': b'3: +    rclcpp::spin_some(node);\n'}
[11.430450] (control) StdoutLine: {'line': b'3: +    rate.sleep();\n'}
[11.430492] (control) StdoutLine: {'line': b'3: +  }\n'}
[11.430533] (control) StdoutLine: {'line': b'3: +\n'}
[11.430574] (control) StdoutLine: {'line': b'3: +  status = false;\n'}
[11.430615] (control) StdoutLine: {'line': b'3: +}\n'}
[11.430657] (control) StdoutLine: {'line': b'3: +\n'}
[11.430697] (control) StdoutLine: {'line': b'3: +void centeringGateLidarVelocity(\n'}
[11.430738] (control) StdoutLine: {'line': b'3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,\n'}
[11.430780] (control) StdoutLine: {'line': b'3: +  geometry_msgs::msg::PoseStamped & posee, float gate_width,\n'}
[11.430821] (control) StdoutLine: {'line': b'3: +  float tolerance, bool & status, float max_velocity,\n'}
[11.430862] (control) StdoutLine: {'line': b'3: +  float proportional_gain, float max_time)\n'}
[11.430902] (control) StdoutLine: {'line': b'3: +{\n'}
[11.430943] (control) StdoutLine: {'line': b'3: +  /**\n'}
[11.430983] (control) StdoutLine: {'line': b'3: +   * Center the drone between two gate posts using 2D lidar with VELOCITY CONTROL\n'}
[11.431024] (control) StdoutLine: {'line': b'3: +   * This version uses proportional velocity control for smooth, gradual centering\n'}
[11.431067] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.431108] (control) StdoutLine: {'line': b'3: +   * Strategy:\n'}
[11.431148] (control) StdoutLine: {'line': b'3: +   * 1. Detect gate posts using lidar\n'}
[11.431192] (control) StdoutLine: {'line': b'3: +   * 2. Calculate lateral offset from gate center\n'}
[11.431238] (control) StdoutLine: {'line': b'3: +   * 3. Calculate proportional velocity based on offset\n'}
[11.431280] (control) StdoutLine: {'line': b'3: +   * 4. Publish velocity command continuously\n'}
[11.431320] (control) StdoutLine: {'line': b'3: +   * 5. When centered, stop and hold position\n'}
[11.431361] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.431403] (control) StdoutLine: {'line': b'3: +   * Advantages over position control:\n'}
[11.431443] (control) StdoutLine: {'line': b'3: +   * - Smooth, continuous movement (no jerky steps)\n'}
[11.431484] (control) StdoutLine: {'line': b'3: +   * - Automatic deceleration as approaching center\n'}
[11.431525] (control) StdoutLine: {'line': b'3: +   * - Better safety with explicit velocity limiting\n'}
[11.431565] (control) StdoutLine: {'line': b'3: +   * - Real-time feedback and correction\n'}
[11.431606] (control) StdoutLine: {'line': b'3: +   */\n'}
[11.431648] (control) StdoutLine: {'line': b'3: +\n'}
[11.431689] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.431731] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Velocity Control Lidar Centering Start ygy... (gate width: %.2f m, tolerance: %.2f m)...", gate_width,\n'}
[11.431773] (control) StdoutLine: {'line': b'3: +    tolerance);\n'}
[11.431816] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.431855] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Max velocity: %.2f m/s, Proportional gain: %.2f", max_velocity,\n'}
[11.431898] (control) StdoutLine: {'line': b'3: +    proportional_gain);\n'}
[11.431938] (control) StdoutLine: {'line': b'3: +\n'}
[11.431979] (control) StdoutLine: {'line': b'3: +  auto start_time = node->now();\n'}
[11.432020] (control) StdoutLine: {'line': b'3: +  status = false;\n'}
[11.432061] (control) StdoutLine: {'line': b'3: +\n'}
[11.432102] (control) StdoutLine: {'line': b'3: +  int consecutive_centered_count = 0;\n'}
[11.432141] (control) StdoutLine: {'line': b'3: +  int required_consecutive = 5;   // Require 5 consecutive "centered" readings for stability (0.5 sec at 10Hz)\n'}
[11.432183] (control) StdoutLine: {'line': b'3: +\n'}
[11.432236] (control) StdoutLine: {'line': b'3: +  // Get initial position for reference\n'}
[11.432279] (control) StdoutLine: {'line': b'3: +  geometry_msgs::msg::PoseStamped initial_pose = node->getCurrentLocalPose();\n'}
[11.432322] (control) StdoutLine: {'line': b'3: +  float initial_z = initial_pose.pose.position.z;\n'}
[11.432363] (control) StdoutLine: {'line': b'3: +\n'}
[11.432403] (control) StdoutLine: {'line': b'3: +  while (rclcpp::ok()) {\n'}
[11.432444] (control) StdoutLine: {'line': b'3: +    // Check timeout\n'}
[11.432484] (control) StdoutLine: {'line': b'3: +    if ((node->now() - start_time).seconds() > max_time) {\n'}
[11.432525] (control) StdoutLine: {'line': b'3: +      RCLCPP_WARN(node->get_logger(), "Gate centering timeout after %.1f seconds", max_time);\n'}
[11.432567] (control) StdoutLine: {'line': b'3: +\n'}
[11.432606] (control) StdoutLine: {'line': b'3: +      // Stop the drone (global frame)\n'}
[11.432646] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.432687] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.stamp = node->now();\n'}
[11.432728] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.frame_id = "map";       // Global frame\n'}
[11.432769] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.x = 0.0;\n'}
[11.432810] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.y = 0.0;\n'}
[11.432852] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.z = 0.0;\n'}
[11.432893] (control) StdoutLine: {'line': b'3: +      node->publishLocalVelocity(stop_cmd);\n'}
[11.432933] (control) StdoutLine: {'line': b'3: +\n'}
[11.432973] (control) StdoutLine: {'line': b'3: +      status = false;\n'}
[11.433013] (control) StdoutLine: {'line': b'3: +      return;\n'}
[11.433061] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.433102] (control) StdoutLine: {'line': b'3: +\n'}
[11.433140] (control) StdoutLine: {'line': b'3: +    // Detect gate posts\n'}
[11.433182] (control) StdoutLine: {'line': b'3: +    float left_angle, right_angle, left_dist, right_dist;\n'}
[11.433234] (control) StdoutLine: {'line': b'3: +    if (!detectGatePosts(node, left_angle, right_angle, left_dist, right_dist, gate_width)) {\n'}
[11.433278] (control) StdoutLine: {'line': b'3: +      RCLCPP_WARN_THROTTLE(\n'}
[11.433320] (control) StdoutLine: {'line': b'3: +        node->get_logger(), *node->get_clock(), 2000,\n'}
[11.433360] (control) StdoutLine: {'line': b'3: +        "Gate Ga kedetek, stopping movement...");\n'}
[11.433402] (control) StdoutLine: {'line': b'3: +\n'}
[11.433444] (control) StdoutLine: {'line': b'3: +      // Stop the drone if gate is lost (global frame)\n'}
[11.433484] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.433525] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.stamp = node->now();\n'}
[11.433565] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.frame_id = "map";       // Global frame\n'}
[11.433606] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.x = 0.0;\n'}
[11.433648] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.y = 0.0;\n'}
[11.433686] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.z = 0.0;\n'}
[11.433725] (control) StdoutLine: {'line': b'3: +      node->publishLocalVelocity(stop_cmd);\n'}
[11.433765] (control) StdoutLine: {'line': b'3: +\n'}
[11.433803] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count = 0;\n'}
[11.433842] (control) StdoutLine: {'line': b'3: +      rclcpp::spin_some(node);\n'}
[11.433881] (control) StdoutLine: {'line': b'3: +      rate.sleep();\n'}
[11.433920] (control) StdoutLine: {'line': b'3: +      continue;\n'}
[11.433960] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.433999] (control) StdoutLine: {'line': b'3: +\n'}
[11.434037] (control) StdoutLine: {'line': b'3: +    // Calculate positions in Cartesian coordinates (body frame)\n'}
[11.434075] (control) StdoutLine: {'line': b'3: +    float left_x = left_dist * cos(left_angle);\n'}
[11.434114] (control) StdoutLine: {'line': b'3: +    float left_y = left_dist * sin(left_angle);\n'}
[11.434153] (control) StdoutLine: {'line': b'3: +    float right_x = right_dist * cos(right_angle);\n'}
[11.434193] (control) StdoutLine: {'line': b'3: +    float right_y = right_dist * sin(right_angle);\n'}
[11.434244] (control) StdoutLine: {'line': b'3: +\n'}
[11.434285] (control) StdoutLine: {'line': b'3: +    // Calculate center point of the gate\n'}
[11.434324] (control) StdoutLine: {'line': b'3: +    float center_x = (left_x + right_x) / 2.0;\n'}
[11.434362] (control) StdoutLine: {'line': b'3: +    float center_y = (left_y + right_y) / 2.0;\n'}
[11.434402] (control) StdoutLine: {'line': b'3: +\n'}
[11.434441] (control) StdoutLine: {'line': b'3: +    // The lateral offset (positive = gate center is to the LEFT)\n'}
[11.434480] (control) StdoutLine: {'line': b'3: +    float lateral_offset = center_y;\n'}
[11.434523] (control) StdoutLine: {'line': b'3: +\n'}
[11.434562] (control) StdoutLine: {'line': b'3: +    RCLCPP_INFO_THROTTLE(\n'}
[11.434601] (control) StdoutLine: {'line': b'3: +      node->get_logger(), *node->get_clock(), 500,\n'}
[11.434640] (control) StdoutLine: {'line': b'3: +      "Gate center offset: %.3f m (forward: %.2f m)", lateral_offset, center_x);\n'}
[11.434681] (control) StdoutLine: {'line': b'3: +\n'}
[11.434719] (control) StdoutLine: {'line': b"3: +    // Check if we're centered\n"}
[11.434757] (control) StdoutLine: {'line': b'3: +    if (fabs(lateral_offset) < tolerance) {\n'}
[11.434797] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count++;\n'}
[11.434837] (control) StdoutLine: {'line': b'3: +\n'}
[11.434875] (control) StdoutLine: {'line': b'3: +      // Publish zero velocity to stop (in global frame)\n'}
[11.434915] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.434961] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.stamp = node->now();\n'}
[11.435004] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.frame_id = "map";       // Global frame\n'}
[11.435051] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.x = 0.0;\n'}
[11.435096] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.y = 0.0;\n'}
[11.435138] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.z = 0.0;\n'}
[11.435180] (control) StdoutLine: {'line': b'3: +      node->publishLocalVelocity(stop_cmd);\n'}
[11.435233] (control) StdoutLine: {'line': b'3: +\n'}
[11.435277] (control) StdoutLine: {'line': b'3: +      RCLCPP_INFO(\n'}
[11.435318] (control) StdoutLine: {'line': b'3: +        node->get_logger(),\n'}
[11.435360] (control) StdoutLine: {'line': b'3: +        "Centered! (%.3f m offset, %d/%d consecutive)",\n'}
[11.435402] (control) StdoutLine: {'line': b'3: +        lateral_offset, consecutive_centered_count, required_consecutive);\n'}
[11.435443] (control) StdoutLine: {'line': b'3: +\n'}
[11.435484] (control) StdoutLine: {'line': b'3: +      if (consecutive_centered_count >= required_consecutive) {\n'}
[11.435525] (control) StdoutLine: {'line': b'3: +        RCLCPP_INFO(node->get_logger(), "Lidar Vel Control : Gate centering successful");\n'}
[11.435566] (control) StdoutLine: {'line': b'3: +\n'}
[11.435607] (control) StdoutLine: {'line': b'3: +        // Hold position briefly to ensure stability\n'}
[11.435648] (control) StdoutLine: {'line': b'3: +        holdPosition(node, rate, posee, 1.0);\n'}
[11.435689] (control) StdoutLine: {'line': b'3: +\n'}
[11.435730] (control) StdoutLine: {'line': b'3: +        status = true;\n'}
[11.435772] (control) StdoutLine: {'line': b'3: +        posee = node->getCurrentLocalPose();\n'}
[11.435814] (control) StdoutLine: {'line': b'3: +        return;\n'}
[11.435855] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.435895] (control) StdoutLine: {'line': b'3: +    } else {\n'}
[11.435936] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count = 0;\n'}
[11.435976] (control) StdoutLine: {'line': b'3: +\n'}
[11.436015] (control) StdoutLine: {'line': b'3: +      // Calculate proportional velocity in BODY FRAME\n'}
[11.436055] (control) StdoutLine: {'line': b'3: +      // In body frame: X=forward, Y=left, Z=up\n'}
[11.436097] (control) StdoutLine: {'line': b'3: +      // Lidar detection already in body frame, so lateral_offset is already correct orientation\n'}
[11.436138] (control) StdoutLine: {'line': b'3: +      // Positive offset = gate is LEFT, need positive Y velocity (strafe left)\n'}
[11.436178] (control) StdoutLine: {'line': b'3: +      // Negative offset = gate is RIGHT, need negative Y velocity (strafe right)\n'}
[11.436229] (control) StdoutLine: {'line': b'3: +\n'}
[11.436272] (control) StdoutLine: {'line': b'3: +      float target_velocity_body_y = proportional_gain * lateral_offset;        // Lateral velocity in body frame\n'}
[11.436316] (control) StdoutLine: {'line': b'3: +\n'}
[11.436355] (control) StdoutLine: {'line': b'3: +      // Limit velocity to max_velocity\n'}
[11.436394] (control) StdoutLine: {'line': b'3: +      if (fabs(target_velocity_body_y) > max_velocity) {\n'}
[11.436433] (control) StdoutLine: {'line': b'3: +        target_velocity_body_y = (target_velocity_body_y > 0) ? max_velocity : -max_velocity;\n'}
[11.436474] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.436513] (control) StdoutLine: {'line': b'3: +\n'}
[11.436553] (control) StdoutLine: {'line': b'3: +      // Apply velocity deadband to avoid tiny oscillations\n'}
[11.436591] (control) StdoutLine: {'line': b'3: +      float velocity_deadband = 0.02;       // 2 cm/s deadband\n'}
[11.436631] (control) StdoutLine: {'line': b'3: +      if (fabs(target_velocity_body_y) < velocity_deadband) {\n'}
[11.436670] (control) StdoutLine: {'line': b'3: +        target_velocity_body_y = 0.0;\n'}
[11.436709] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.436751] (control) StdoutLine: {'line': b'3: +\n'}
[11.436789] (control) StdoutLine: {'line': b'3: +      // Get current pose and heading for global frame velocity\n'}
[11.436829] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();\n'}
[11.436869] (control) StdoutLine: {'line': b'3: +      float current_yaw = getHeading(current_pose.pose.orientation);\n'}
[11.436909] (control) StdoutLine: {'line': b'3: +\n'}
[11.436949] (control) StdoutLine: {'line': b'3: +      // Transform body frame velocity to global frame\n'}
[11.436987] (control) StdoutLine: {'line': b'3: +      // Body frame: X=forward(0), Y=left(target_velocity_body_y), Z=up\n'}
[11.437026] (control) StdoutLine: {'line': b'3: +      // Global frame transformation:\n'}
[11.437066] (control) StdoutLine: {'line': b'3: +      // vx_global = vx_body * cos(yaw) - vy_body * sin(yaw)\n'}
[11.437106] (control) StdoutLine: {'line': b'3: +      // vy_global = vx_body * sin(yaw) + vy_body * cos(yaw)\n'}
[11.437145] (control) StdoutLine: {'line': b'3: +      float vx_body = 0.0;        // No forward/backward in body frame\n'}
[11.437186] (control) StdoutLine: {'line': b'3: +      float vy_body = target_velocity_body_y;        // Lateral strafe in body frame\n'}
[11.437230] (control) StdoutLine: {'line': b'3: +\n'}
