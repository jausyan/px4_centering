[11.480861] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.480900] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.stamp = node->now();\n'}
[11.480940] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.frame_id = "map";\n'}
[11.480981] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.x = 0.0;\n'}
[11.481020] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.y = 0.0;\n'}
[11.481061] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.z = 0.0;\n'}
[11.481103] (control) StdoutLine: {'line': b'3: -            node->publishLocalVelocity(stop_cmd);\n'}
