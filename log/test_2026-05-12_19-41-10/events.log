[11.191423] (control) StdoutLine: {'line': b'3: +    // Calculate current distance to target (using relative altitude for Z)\n'}
[11.191469] (control) StdoutLine: {'line': b'3: +    float dx = target_x - current_pose.pose.position.x;\n'}
[11.191512] (control) StdoutLine: {'line': b'3: +    float dy = target_y - current_pose.pose.position.y;\n'}
[11.191555] (control) StdoutLine: {'line': b'3: +    float current_relative_z_loop = node->getRelativeAltitude();\n'}
[11.191600] (control) StdoutLine: {'line': b'3: +    float dz = target_z - current_relative_z_loop;\n'}
[11.191644] (control) StdoutLine: {'line': b'3: +    float current_distance = sqrt(dx * dx + dy * dy + dz * dz);\n'}
[11.191690] (control) StdoutLine: {'line': b'3: +\n'}
[11.191731] (control) StdoutLine: {'line': b"3: +    // Check if we've reached the target\n"}
[11.191776] (control) StdoutLine: {'line': b'3: +    if (current_distance < tolerance) {\n'}
