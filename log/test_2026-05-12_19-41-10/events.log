[11.463979] (control) StdoutLine: {'line': b'3: -            \n'}
[11.464018] (control) StdoutLine: {'line': b'3: -            // Calculate proportional velocity in BODY FRAME\n'}
[11.464058] (control) StdoutLine: {'line': b'3: -            // In body frame: X=forward, Y=left, Z=up\n'}
[11.464098] (control) StdoutLine: {'line': b'3: -            // Lidar detection already in body frame, so lateral_offset is already correct orientation\n'}
[11.464137] (control) StdoutLine: {'line': b'3: -            // Positive offset = gate is LEFT, need positive Y velocity (strafe left)\n'}
[11.464178] (control) StdoutLine: {'line': b'3: -            // Negative offset = gate is RIGHT, need negative Y velocity (strafe right)\n'}
