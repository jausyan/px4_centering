[11.460811] (control) StdoutLine: {'line': b'3: -            // Stop the drone (global frame)\n'}
[11.460850] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.460890] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.stamp = node->now();\n'}
