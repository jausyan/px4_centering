[11.188866] (control) StdoutLine: {'line': b'3: +void executeLocalWaypointMoveVelocity(\n'}
[11.188915] (control) StdoutLine: {'line': b'3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,\n'}
