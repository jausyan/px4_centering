[11.192180] (control) StdoutLine: {'line': b'3: +\n'}
[11.192233] (control) StdoutLine: {'line': b'3: +    // Normalize direction and multiply by max_velocity\n'}
[11.192281] (control) StdoutLine: {'line': b'3: +    vel_cmd.twist.linear.x = (dx / current_distance) * max_velocity;\n'}
[11.192325] (control) StdoutLine: {'line': b'3: +    vel_cmd.twist.linear.y = (dy / current_distance) * max_velocity;\n'}
[11.192369] (control) StdoutLine: {'line': b'3: +\n'}
[11.192414] (control) StdoutLine: {'line': b'3: +    // Add deadband for Z to prevent altitude drift\n'}
[11.192458] (control) StdoutLine: {'line': b'3: +    if (std::abs(dz) > 0.15f) {      // Only control altitude if error > 15cm\n'}
[11.192504] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.linear.z = (dz / current_distance) * max_velocity;\n'}
[11.192549] (control) StdoutLine: {'line': b'3: +    } else {\n'}
[11.192596] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.linear.z = 0.0;        // Hold altitude when close enough\n'}
[11.192640] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.192683] (control) StdoutLine: {'line': b'3: +\n'}
[11.192728] (control) StdoutLine: {'line': b'3: +    // Publish velocity command\n'}
[11.192771] (control) StdoutLine: {'line': b'3: +    node->publishLocalVelocity(vel_cmd);\n'}
[11.192814] (control) StdoutLine: {'line': b'3: +\n'}
