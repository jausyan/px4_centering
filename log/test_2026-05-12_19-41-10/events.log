[11.191864] (control) StdoutLine: {'line': b'3: +      break;\n'}
[11.191908] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.191960] (control) StdoutLine: {'line': b'3: +\n'}
[11.192005] (control) StdoutLine: {'line': b'3: +    // Calculate velocity direction (unit vector towards target)\n'}
[11.192049] (control) StdoutLine: {'line': b'3: +    geometry_msgs::msg::TwistStamped vel_cmd;\n'}
[11.192094] (control) StdoutLine: {'line': b'3: +    vel_cmd.header.stamp = node->now();\n'}
