[11.320708] (control) StdoutLine: {'line': b'3: +  while (rclcpp::ok()) {\n'}
[11.320757] (control) StdoutLine: {'line': b'3: +    rclcpp::Time current_time = node->now();\n'}
[11.320803] (control) StdoutLine: {'line': b'3: +    double elapsed_time = (current_time - start_time).seconds();\n'}
[11.320849] (control) StdoutLine: {'line': b'3: +\n'}
[11.320893] (control) StdoutLine: {'line': b'3: +    // PX4 CRITICAL: Must stream setpoint continuously\n'}
