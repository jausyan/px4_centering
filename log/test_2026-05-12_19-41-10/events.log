[11.459372] (control) StdoutLine: {'line': b'3: -    /**\n'}
[11.459411] (control) StdoutLine: {'line': b'3: -     * Center the drone between two gate posts using 2D lidar with VELOCITY CONTROL\n'}
[11.459452] (control) StdoutLine: {'line': b'3: -     * This version uses proportional velocity control for smooth, gradual centering\n'}
[11.459492] (control) StdoutLine: {'line': b'3: -     * \n'}
[11.459532] (control) StdoutLine: {'line': b'3: -     * Strategy:\n'}
[11.459572] (control) StdoutLine: {'line': b'3: -     * 1. Detect gate posts using lidar\n'}
[11.459611] (control) StdoutLine: {'line': b'3: -     * 2. Calculate lateral offset from gate center\n'}
[11.459649] (control) StdoutLine: {'line': b'3: -     * 3. Calculate proportional velocity based on offset\n'}
[11.459689] (control) StdoutLine: {'line': b'3: -     * 4. Publish velocity command continuously\n'}
[11.459727] (control) StdoutLine: {'line': b'3: -     * 5. When centered, stop and hold position\n'}
[11.459765] (control) StdoutLine: {'line': b'3: -     * \n'}
[11.459804] (control) StdoutLine: {'line': b'3: -     * Advantages over position control:\n'}
[11.459843] (control) StdoutLine: {'line': b'3: -     * - Smooth, continuous movement (no jerky steps)\n'}
[11.459886] (control) StdoutLine: {'line': b'3: -     * - Automatic deceleration as approaching center\n'}
[11.459925] (control) StdoutLine: {'line': b'3: -     * - Better safety with explicit velocity limiting\n'}
[11.459965] (control) StdoutLine: {'line': b'3: -     * - Real-time feedback and correction\n'}
[11.460004] (control) StdoutLine: {'line': b'3: -     */\n'}
[11.460044] (control) StdoutLine: {'line': b'3: -    \n'}
[11.460083] (control) StdoutLine: {'line': b'3: -    RCLCPP_INFO(node->get_logger(), "Velocity Control Lidar Centering Start ygy... (gate width: %.2f m, tolerance: %.2f m)...", gate_width, tolerance);\n'}
[11.460124] (control) StdoutLine: {'line': b'3: -    RCLCPP_INFO(node->get_logger(), "Max velocity: %.2f m/s, Proportional gain: %.2f", max_velocity, proportional_gain);\n'}
[11.460165] (control) StdoutLine: {'line': b'3: -    \n'}
[11.460205] (control) StdoutLine: {'line': b'3: -    auto start_time = node->now();\n'}
[11.460252] (control) StdoutLine: {'line': b'3: -    status = false;\n'}
