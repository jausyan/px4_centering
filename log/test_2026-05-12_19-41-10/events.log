[11.460374] (control) StdoutLine: {'line': b'3: -    int required_consecutive = 5; // Require 5 consecutive "centered" readings for stability (0.5 sec at 10Hz)\n'}
[11.460416] (control) StdoutLine: {'line': b'3: -    \n'}
