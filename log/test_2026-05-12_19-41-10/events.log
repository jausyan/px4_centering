[11.482829] (control) StdoutLine: {'line': b'3: -            float vy_global = vx_body * sin(current_yaw) + vy_body * cos(current_yaw);\n'}
[11.482870] (control) StdoutLine: {'line': b'3: -            \n'}
[11.482909] (control) StdoutLine: {'line': b'3: -            // Altitude control (global frame, Z is same in both frames)\n'}
[11.482948] (control) StdoutLine: {'line': b'3: -            float altitude_error = initial_z - current_pose.pose.position.z;\n'}
[11.482987] (control) StdoutLine: {'line': b'3: -            float target_velocity_z = 0.0;\n'}
[11.483026] (control) StdoutLine: {'line': b'3: -            \n'}
[11.483067] (control) StdoutLine: {'line': b'3: -            // Gentle altitude correction\n'}
