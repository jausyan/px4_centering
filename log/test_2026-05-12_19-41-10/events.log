[11.329198] (control) StdoutLine: {'line': b'3: +void correctAltitude(\n'}
[11.329254] (control) StdoutLine: {'line': b'3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,\n'}
[11.329298] (control) StdoutLine: {'line': b'3: +  geometry_msgs::msg::PoseStamped & posee, double height,\n'}
[11.329340] (control) StdoutLine: {'line': b'3: +  float & corrected_rel_alt, double max_speed)\n'}
[11.329381] (control) StdoutLine: {'line': b'3: +{\n'}
[11.329423] (control) StdoutLine: {'line': b'3: +  /**\n'}
[11.329465] (control) StdoutLine: {'line': b"3: +   * Correct the drone's altitude to a specified rangefinder reading by adjusting its velocity.\n"}
[11.329506] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.329546] (control) StdoutLine: {'line': b'3: +   * parameters:\n'}
[11.329586] (control) StdoutLine: {'line': b'3: +   * - node: shared pointer to the DroneController node instance.\n'}
[11.329628] (control) StdoutLine: {'line': b'3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.\n'}
[11.329670] (control) StdoutLine: {'line': b'3: +   * - vel_pub: shared pointer to the rclcpp::Publisher for publishing velocity commands.\n'}
[11.329712] (control) StdoutLine: {'line': b'3: +   * - height: double value representing the target altitude in meters.\n'}
[11.329754] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.329796] (control) StdoutLine: {'line': b'3: +   * returns:\n'}
[11.329837] (control) StdoutLine: {'line': b'3: +   * - posee: reference to the geometry_msgs::msg::PoseStamped object representing the current pose of the drone.\n'}
[11.329881] (control) StdoutLine: {'line': b"3: +   * - The correct relative altitude after adjusting the drone's position. ready to be used for sendGlobalRaw.\n"}
[11.329925] (control) StdoutLine: {'line': b'3: +   */\n'}
[11.329966] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(node->get_logger(), "fixing altitude..");\n'}
[11.330008] (control) StdoutLine: {'line': b'3: +  geometry_msgs::msg::Twist cmd_vel = geometry_msgs::msg::Twist();\n'}
[11.330051] (control) StdoutLine: {'line': b'3: +  rclcpp::Time last_correct_time = rclcpp::Time(0, 0);\n'}
[11.330093] (control) StdoutLine: {'line': b'3: +  bool hit = false;\n'}
[11.330136] (control) StdoutLine: {'line': b'3: +\n'}
[11.330177] (control) StdoutLine: {'line': b'3: +  const float MAX_SPEED = max_speed;\n'}
[11.330228] (control) StdoutLine: {'line': b'3: +\n'}
[11.330273] (control) StdoutLine: {'line': b'3: +  const float P = 1.0;\n'}
[11.330313] (control) StdoutLine: {'line': b'3: +  const float I = 0.0;\n'}
[11.330355] (control) StdoutLine: {'line': b'3: +  const float D = 0.0;\n'}
[11.330395] (control) StdoutLine: {'line': b'3: +\n'}
[11.330436] (control) StdoutLine: {'line': b'3: +  float total_error = 0;\n'}
[11.330477] (control) StdoutLine: {'line': b'3: +  float last_error = 0;\n'}
[11.330517] (control) StdoutLine: {'line': b'3: +\n'}
[11.330559] (control) StdoutLine: {'line': b'3: +  while\n'}
[11.330601] (control) StdoutLine: {'line': b'3: +  (\n'}
[11.330641] (control) StdoutLine: {'line': b'3: +    !hit ||\n'}
[11.330683] (control) StdoutLine: {'line': b'3: +    (rclcpp::ok() && abs(node->getCurrentRangefinder().range - height) > 0.05) ||\n'}
[11.330724] (control) StdoutLine: {'line': b'3: +    (hit && node->now() - last_correct_time <= rclcpp::Duration::from_seconds(2.0))\n'}
[11.330767] (control) StdoutLine: {'line': b'3: +  )\n'}
[11.330807] (control) StdoutLine: {'line': b'3: +  {\n'}
[11.330846] (control) StdoutLine: {'line': b'3: +    total_error += height - node->getCurrentRangefinder().range;\n'}
[11.330887] (control) StdoutLine: {'line': b'3: +    cmd_vel.linear.x = 0.0;\n'}
[11.330929] (control) StdoutLine: {'line': b'3: +    cmd_vel.linear.y = 0.0;\n'}
[11.330969] (control) StdoutLine: {'line': b'3: +    cmd_vel.linear.z =\n'}
[11.331011] (control) StdoutLine: {'line': b'3: +      limit(\n'}
[11.331052] (control) StdoutLine: {'line': b'3: +      MAX_SPEED,\n'}
[11.331094] (control) StdoutLine: {'line': b'3: +      P * (height - node->getCurrentRangefinder().range) + I * (total_error) + D *\n'}
[11.331134] (control) StdoutLine: {'line': b'3: +      (last_error - (height - node->getCurrentRangefinder().range)));\n'}
[11.331175] (control) StdoutLine: {'line': b'3: +\n'}
[11.331227] (control) StdoutLine: {'line': b'3: +    RCLCPP_INFO(\n'}
[11.331276] (control) StdoutLine: {'line': b'3: +      node->get_logger(), "height: %f current_alt.range: %f", height,\n'}
[11.331319] (control) StdoutLine: {'line': b'3: +      node->getCurrentRangefinder().range);\n'}
[11.331361] (control) StdoutLine: {'line': b'3: +    last_error = (height - node->getCurrentRangefinder().range);\n'}
[11.331405] (control) StdoutLine: {'line': b'3: +    node->publishLocalVelocityUnstamped(cmd_vel);\n'}
[11.331446] (control) StdoutLine: {'line': b'3: +    rclcpp::spin_some(node);\n'}
[11.331487] (control) StdoutLine: {'line': b'3: +    rate.sleep();\n'}
[11.331528] (control) StdoutLine: {'line': b'3: +\n'}
[11.331568] (control) StdoutLine: {'line': b'3: +    if (!(abs(node->getCurrentRangefinder().range - height) > 0.05) && !hit) {\n'}
[11.331610] (control) StdoutLine: {'line': b'3: +      last_correct_time = node->now();\n'}
[11.331659] (control) StdoutLine: {'line': b'3: +      hit = true;\n'}
[11.331699] (control) StdoutLine: {'line': b'3: +      RCLCPP_INFO(node->get_logger(), "HIT!, last_correct_time: %f", last_correct_time.seconds());\n'}
[11.331740] (control) StdoutLine: {'line': b'3: +    } else if ((abs(node->getCurrentRangefinder().range - height) > 0.05)) {\n'}
[11.331782] (control) StdoutLine: {'line': b'3: +      RCLCPP_INFO(node->get_logger(), "left the tolerance zone, resetting");\n'}
[11.331822] (control) StdoutLine: {'line': b'3: +      hit = false;\n'}
[11.331862] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.331901] (control) StdoutLine: {'line': b'3: +\n'}
[11.331941] (control) StdoutLine: {'line': b'3: +  }\n'}
[11.331982] (control) StdoutLine: {'line': b'3: +  corrected_rel_alt = node->getCurrentRelAlt().data;\n'}
[11.332023] (control) StdoutLine: {'line': b'3: +  posee = node->getCurrentLocalPose();\n'}
[11.332064] (control) StdoutLine: {'line': b'3: +}\n'}
