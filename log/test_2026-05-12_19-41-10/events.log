[11.463015] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.463053] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.stamp = node->now();\n'}
[11.463092] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.frame_id = "map"; // Global frame\n'}
[11.463130] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.x = 0.0;\n'}
