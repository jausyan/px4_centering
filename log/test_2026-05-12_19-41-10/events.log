[11.465295] (control) StdoutLine: {'line': b'3: -            float vx_global = vx_body * cos(current_yaw) - vy_body * sin(current_yaw);\n'}
[11.465335] (control) StdoutLine: {'line': b'3: -            float vy_global = vx_body * sin(current_yaw) + vy_body * cos(current_yaw);\n'}
[11.465375] (control) StdoutLine: {'line': b'3: -            \n'}
[11.465415] (control) StdoutLine: {'line': b'3: -            // Altitude control (global frame, Z is same in both frames)\n'}
[11.465453] (control) StdoutLine: {'line': b'3: -            float altitude_error = initial_z - current_pose.pose.position.z;\n'}
[11.465492] (control) StdoutLine: {'line': b'3: -            float target_velocity_z = 0.0;\n'}
[11.465539] (control) StdoutLine: {'line': b'3: -            \n'}
