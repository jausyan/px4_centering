[11.189002] (control) StdoutLine: {'line': b'3: +  float up_z, float yaw_angle, float max_velocity, float tolerance)\n'}
[11.189052] (control) StdoutLine: {'line': b'3: +{\n'}
[11.189095] (control) StdoutLine: {'line': b'3: +  /**\n'}
[11.189139] (control) StdoutLine: {'line': b'3: +   * Execute a local waypoint movement using VELOCITY CONTROL for smooth, controlled movement\n'}
[11.189185] (control) StdoutLine: {'line': b"3: +   * Movement is relative to the current drone's heading (body frame)\n"}
[11.189242] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.189287] (control) StdoutLine: {'line': b'3: +   * Unlike executeLocalWaypointMove() which uses position control and can cause sudden movements,\n'}
[11.189331] (control) StdoutLine: {'line': b'3: +   * this function sends velocity setpoints continuously at max_velocity for smooth motion.\n'}
[11.189375] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.189416] (control) StdoutLine: {'line': b'3: +   * Time taken = distance / max_velocity\n'}
[11.189459] (control) StdoutLine: {'line': b'3: +   * Example: 2 meters at 0.2 m/s = 10 seconds\n'}
[11.189501] (control) StdoutLine: {'line': b'3: +   */\n'}
[11.189544] (control) StdoutLine: {'line': b'3: +\n'}
[11.189586] (control) StdoutLine: {'line': b'3: +  // Get current position and heading\n'}
[11.189628] (control) StdoutLine: {'line': b'3: +  geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();\n'}
[11.189675] (control) StdoutLine: {'line': b'3: +  float current_yaw = getHeading(current_pose.pose.orientation);\n'}
[11.189723] (control) StdoutLine: {'line': b'3: +\n'}
[11.189768] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(node->get_logger(), "=== Velocity Control Movement ===");\n'}
[11.189813] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(node->get_logger(), "Current heading: %.2f degrees", current_yaw * 180.0 / M_PI);\n'}
[11.189857] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.189901] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Body frame: forward=%.2f m, left=%.2f m, up=%.2f m", forward_x, left_y,\n'}
[11.189945] (control) StdoutLine: {'line': b'3: +    up_z);\n'}
[11.189989] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(node->get_logger(), "Max velocity: %.2f m/s", max_velocity);\n'}
[11.190035] (control) StdoutLine: {'line': b'3: +\n'}
[11.190077] (control) StdoutLine: {'line': b'3: +  // Transform body-frame movement to global frame using current heading\n'}
[11.190120] (control) StdoutLine: {'line': b'3: +  float global_x = forward_x * cos(current_yaw) - left_y * sin(current_yaw);\n'}
[11.190165] (control) StdoutLine: {'line': b'3: +  float global_y = forward_x * sin(current_yaw) + left_y * cos(current_yaw);\n'}
[11.190211] (control) StdoutLine: {'line': b'3: +\n'}
[11.190258] (control) StdoutLine: {'line': b'3: +  // Calculate target position in global frame (using relative altitude)\n'}
[11.190303] (control) StdoutLine: {'line': b'3: +  float target_x = current_pose.pose.position.x + global_x;\n'}
[11.190346] (control) StdoutLine: {'line': b'3: +  float target_y = current_pose.pose.position.y + global_y;\n'}
[11.190390] (control) StdoutLine: {'line': b'3: +  float current_relative_z = node->getRelativeAltitude();\n'}
[11.190434] (control) StdoutLine: {'line': b'3: +  float target_z = current_relative_z + up_z;\n'}
[11.190478] (control) StdoutLine: {'line': b'3: +\n'}
[11.190522] (control) StdoutLine: {'line': b'3: +  // print log every 0.2 seconds\n'}
[11.190566] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO_THROTTLE(\n'}
[11.190613] (control) StdoutLine: {'line': b'3: +    node->get_logger(),\n'}
[11.190661] (control) StdoutLine: {'line': b'3: +    *node->get_clock(), 200, "Target global: x=%.2f, y=%.2f, z=%.2f", target_x, target_y, target_z);\n'}
[11.190706] (control) StdoutLine: {'line': b'3: +\n'}
[11.190749] (control) StdoutLine: {'line': b'3: +  // Calculate total distance to travel\n'}
[11.190794] (control) StdoutLine: {'line': b'3: +  float total_distance = sqrt(global_x * global_x + global_y * global_y + up_z * up_z);\n'}
[11.190841] (control) StdoutLine: {'line': b'3: +  float estimated_time = total_distance / max_velocity;\n'}
[11.190886] (control) StdoutLine: {'line': b'3: +\n'}
[11.190929] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.190973] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Total distance: %.2f m, Estimated time: %.1f seconds",\n'}
[11.191018] (control) StdoutLine: {'line': b'3: +    total_distance, estimated_time);\n'}
[11.191061] (control) StdoutLine: {'line': b'3: +\n'}
[11.191103] (control) StdoutLine: {'line': b'3: +  // PX4 OFFBOARD: Use fast rate for continuous streaming\n'}
[11.191146] (control) StdoutLine: {'line': b'3: +  rclcpp::Rate fast_rate(20.0);   // 20Hz\n'}
[11.191189] (control) StdoutLine: {'line': b'3: +\n'}
[11.191248] (control) StdoutLine: {'line': b'3: +  // Main control loop\n'}
[11.191293] (control) StdoutLine: {'line': b'3: +  while (rclcpp::ok()) {\n'}
[11.191337] (control) StdoutLine: {'line': b'3: +    current_pose = node->getCurrentLocalPose();\n'}
