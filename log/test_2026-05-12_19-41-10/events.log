[11.484826] (control) StdoutLine: {'line': b'3: +  float forward_zone_min, float max_lateral_angle)\n'}
[11.484865] (control) StdoutLine: {'line': b'3: +{\n'}
[11.484905] (control) StdoutLine: {'line': b'3: +  /**\n'}
[11.484944] (control) StdoutLine: {'line': b'3: +   * Center the drone to the NEAREST FORWARD GATE using 2D lidar with VELOCITY CONTROL\n'}
[11.484983] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.485023] (control) StdoutLine: {'line': b'3: +   * NEW STRATEGY for multiple gates scenario:\n'}
[11.485061] (control) StdoutLine: {'line': b'3: +   * - Prioritizes gate directly in front (best forward alignment)\n'}
[11.485101] (control) StdoutLine: {'line': b'3: +   * - Filters out gates that are too far to the side\n'}
[11.485143] (control) StdoutLine: {'line': b'3: +   * - Uses forward zone filtering to ignore side/back obstacles\n'}
[11.485184] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.485226] (control) StdoutLine: {'line': b'3: +   * This version uses proportional velocity control for smooth, gradual centering\n'}
[11.485268] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.485308] (control) StdoutLine: {'line': b'3: +   * Strategy:\n'}
[11.485347] (control) StdoutLine: {'line': b'3: +   * 1. Detect NEAREST FORWARD gate posts using enhanced detection algorithm\n'}
[11.485388] (control) StdoutLine: {'line': b'3: +   * 2. Calculate lateral offset from gate center\n'}
[11.485428] (control) StdoutLine: {'line': b'3: +   * 3. Calculate proportional velocity based on offset\n'}
[11.485468] (control) StdoutLine: {'line': b'3: +   * 4. Publish velocity command continuously\n'}
[11.485509] (control) StdoutLine: {'line': b'3: +   * 5. When centered, stop and hold position\n'}
[11.485548] (control) StdoutLine: {'line': b'3: +   *\n'}
[11.485588] (control) StdoutLine: {'line': b'3: +   * Parameters:\n'}
[11.485629] (control) StdoutLine: {'line': b'3: +   * - forward_zone_min: Minimum forward distance to consider (default 0.5m)\n'}
[11.485668] (control) StdoutLine: {'line': b'3: +   * - max_lateral_angle: Max angle to gate center (default 45\xc2\xb0 = 0.785 rad)\n'}
[11.485709] (control) StdoutLine: {'line': b'3: +   */\n'}
[11.485749] (control) StdoutLine: {'line': b'3: +\n'}
[11.485789] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.485829] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Starting NEAREST FORWARD gate centering (gate width: %.2f m, tolerance: %.2f m)...", gate_width,\n'}
[11.485870] (control) StdoutLine: {'line': b'3: +    tolerance);\n'}
[11.485910] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.485949] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Forward zone min: %.2f m, Max lateral angle: %.2f\xc2\xb0",\n'}
[11.485990] (control) StdoutLine: {'line': b'3: +    forward_zone_min, max_lateral_angle * 180.0 / M_PI);\n'}
[11.486029] (control) StdoutLine: {'line': b'3: +  RCLCPP_INFO(\n'}
[11.486069] (control) StdoutLine: {'line': b'3: +    node->get_logger(), "Max velocity: %.2f m/s, Proportional gain: %.2f", max_velocity,\n'}
[11.486113] (control) StdoutLine: {'line': b'3: +    proportional_gain);\n'}
[11.486154] (control) StdoutLine: {'line': b'3: +\n'}
[11.486195] (control) StdoutLine: {'line': b'3: +  auto start_time = node->now();\n'}
[11.486249] (control) StdoutLine: {'line': b'3: +  status = false;\n'}
[11.486291] (control) StdoutLine: {'line': b'3: +\n'}
[11.486333] (control) StdoutLine: {'line': b'3: +  int consecutive_centered_count = 0;\n'}
[11.486374] (control) StdoutLine: {'line': b'3: +  int required_consecutive = 5;   // Require 5 consecutive "centered" readings for stability (0.5 sec at 10Hz)\n'}
[11.486415] (control) StdoutLine: {'line': b'3: +\n'}
[11.486455] (control) StdoutLine: {'line': b'3: +  // Get initial position for reference\n'}
[11.486496] (control) StdoutLine: {'line': b'3: +  geometry_msgs::msg::PoseStamped initial_pose = node->getCurrentLocalPose();\n'}
[11.486537] (control) StdoutLine: {'line': b'3: +  float initial_z = initial_pose.pose.position.z;\n'}
[11.486577] (control) StdoutLine: {'line': b'3: +\n'}
[11.486616] (control) StdoutLine: {'line': b'3: +  while (rclcpp::ok()) {\n'}
[11.486656] (control) StdoutLine: {'line': b'3: +    // Check timeout\n'}
[11.486697] (control) StdoutLine: {'line': b'3: +    if ((node->now() - start_time).seconds() > max_time) {\n'}
[11.486740] (control) StdoutLine: {'line': b'3: +      RCLCPP_WARN(node->get_logger(), "Gate centering timeout after %.1f seconds", max_time);\n'}
[11.486781] (control) StdoutLine: {'line': b'3: +\n'}
[11.486823] (control) StdoutLine: {'line': b'3: +      // Stop the drone (global frame)\n'}
[11.486863] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.486904] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.stamp = node->now();\n'}
[11.486945] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.frame_id = "map";       // Global frame\n'}
[11.486985] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.x = 0.0;\n'}
[11.487023] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.y = 0.0;\n'}
[11.487062] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.z = 0.0;\n'}
[11.487102] (control) StdoutLine: {'line': b'3: +      node->publishLocalVelocity(stop_cmd);\n'}
[11.487144] (control) StdoutLine: {'line': b'3: +\n'}
[11.487182] (control) StdoutLine: {'line': b'3: +      status = false;\n'}
[11.487226] (control) StdoutLine: {'line': b'3: +      return;\n'}
[11.487268] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.487308] (control) StdoutLine: {'line': b'3: +\n'}
[11.487348] (control) StdoutLine: {'line': b'3: +    // Detect NEAREST FORWARD gate posts using enhanced algorithm\n'}
[11.487387] (control) StdoutLine: {'line': b'3: +    float left_angle, right_angle, left_dist, right_dist;\n'}
[11.487428] (control) StdoutLine: {'line': b'3: +    if (!detectGatePostsNear(\n'}
[11.487468] (control) StdoutLine: {'line': b'3: +        node, left_angle, right_angle, left_dist, right_dist,\n'}
[11.487507] (control) StdoutLine: {'line': b'3: +        gate_width, 10.0, forward_zone_min, max_lateral_angle))\n'}
[11.487545] (control) StdoutLine: {'line': b'3: +    {\n'}
[11.487583] (control) StdoutLine: {'line': b'3: +      RCLCPP_WARN_THROTTLE(\n'}
[11.487624] (control) StdoutLine: {'line': b'3: +        node->get_logger(), *node->get_clock(), 2000,\n'}
[11.487665] (control) StdoutLine: {'line': b'3: +        "Nearest forward gate not detected, stopping movement...");\n'}
[11.487706] (control) StdoutLine: {'line': b'3: +\n'}
[11.487744] (control) StdoutLine: {'line': b'3: +      // Stop the drone if gate is lost (global frame)\n'}
[11.487787] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.487831] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.stamp = node->now();\n'}
[11.487874] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.frame_id = "map";       // Global frame\n'}
[11.487917] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.x = 0.0;\n'}
[11.487958] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.y = 0.0;\n'}
[11.488000] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.z = 0.0;\n'}
[11.488039] (control) StdoutLine: {'line': b'3: +      node->publishLocalVelocity(stop_cmd);\n'}
[11.488083] (control) StdoutLine: {'line': b'3: +\n'}
[11.488124] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count = 0;\n'}
[11.488163] (control) StdoutLine: {'line': b'3: +      rclcpp::spin_some(node);\n'}
[11.488204] (control) StdoutLine: {'line': b'3: +      rate.sleep();\n'}
[11.488259] (control) StdoutLine: {'line': b'3: +      continue;\n'}
[11.488300] (control) StdoutLine: {'line': b'3: +    }\n'}
[11.488340] (control) StdoutLine: {'line': b'3: +\n'}
[11.488381] (control) StdoutLine: {'line': b'3: +    // Calculate positions in Cartesian coordinates (body frame)\n'}
[11.488424] (control) StdoutLine: {'line': b'3: +    float left_x = left_dist * cos(left_angle);\n'}
[11.488464] (control) StdoutLine: {'line': b'3: +    float left_y = left_dist * sin(left_angle);\n'}
[11.488504] (control) StdoutLine: {'line': b'3: +    float right_x = right_dist * cos(right_angle);\n'}
[11.488544] (control) StdoutLine: {'line': b'3: +    float right_y = right_dist * sin(right_angle);\n'}
[11.488585] (control) StdoutLine: {'line': b'3: +\n'}
[11.488624] (control) StdoutLine: {'line': b'3: +    // Calculate center point of the gate\n'}
[11.488664] (control) StdoutLine: {'line': b'3: +    float center_x = (left_x + right_x) / 2.0;\n'}
[11.488704] (control) StdoutLine: {'line': b'3: +    float center_y = (left_y + right_y) / 2.0;\n'}
[11.488744] (control) StdoutLine: {'line': b'3: +\n'}
[11.488784] (control) StdoutLine: {'line': b'3: +    // The lateral offset (positive = gate center is to the LEFT)\n'}
[11.488824] (control) StdoutLine: {'line': b'3: +    float lateral_offset = center_y;\n'}
[11.488864] (control) StdoutLine: {'line': b'3: +\n'}
[11.488905] (control) StdoutLine: {'line': b'3: +    RCLCPP_INFO_THROTTLE(\n'}
[11.488946] (control) StdoutLine: {'line': b'3: +      node->get_logger(), *node->get_clock(), 500,\n'}
[11.488986] (control) StdoutLine: {'line': b'3: +      "Nearest gate center offset: %.3f m (forward: %.2f m)", lateral_offset, center_x);\n'}
[11.489025] (control) StdoutLine: {'line': b'3: +\n'}
[11.489064] (control) StdoutLine: {'line': b"3: +    // Check if we're centered\n"}
[11.489104] (control) StdoutLine: {'line': b'3: +    if (fabs(lateral_offset) < tolerance) {\n'}
[11.489144] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count++;\n'}
[11.489184] (control) StdoutLine: {'line': b'3: +\n'}
[11.489234] (control) StdoutLine: {'line': b'3: +      // Publish zero velocity to stop (in global frame)\n'}
[11.489277] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.489317] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.stamp = node->now();\n'}
[11.489357] (control) StdoutLine: {'line': b'3: +      stop_cmd.header.frame_id = "map";\n'}
[11.489397] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.x = 0.0;\n'}
[11.489438] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.y = 0.0;\n'}
[11.489478] (control) StdoutLine: {'line': b'3: +      stop_cmd.twist.linear.z = 0.0;\n'}
[11.489520] (control) StdoutLine: {'line': b'3: +      node->publishLocalVelocity(stop_cmd);\n'}
[11.489560] (control) StdoutLine: {'line': b'3: +\n'}
[11.489600] (control) StdoutLine: {'line': b'3: +      if (consecutive_centered_count >= required_consecutive) {\n'}
[11.489642] (control) StdoutLine: {'line': b'3: +        RCLCPP_INFO(\n'}
[11.489682] (control) StdoutLine: {'line': b'3: +          node->get_logger(),\n'}
[11.489720] (control) StdoutLine: {'line': b'3: +          "Centered on nearest forward gate! (offset: %.3f m, consecutive: %d)",\n'}
[11.489760] (control) StdoutLine: {'line': b'3: +          lateral_offset, consecutive_centered_count);\n'}
[11.489799] (control) StdoutLine: {'line': b'3: +        status = true;\n'}
[11.489838] (control) StdoutLine: {'line': b'3: +        return;\n'}
[11.489877] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.489918] (control) StdoutLine: {'line': b'3: +\n'}
[11.489957] (control) StdoutLine: {'line': b'3: +      RCLCPP_INFO_THROTTLE(\n'}
[11.490000] (control) StdoutLine: {'line': b'3: +        node->get_logger(), *node->get_clock(), 500,\n'}
[11.490040] (control) StdoutLine: {'line': b'3: +        "Centered, waiting for stability... (%d/%d)",\n'}
[11.490080] (control) StdoutLine: {'line': b'3: +        consecutive_centered_count, required_consecutive);\n'}
[11.490119] (control) StdoutLine: {'line': b'3: +    } else {\n'}
[11.490159] (control) StdoutLine: {'line': b'3: +      // Not centered, reset counter\n'}
[11.490198] (control) StdoutLine: {'line': b'3: +      consecutive_centered_count = 0;\n'}
[11.490252] (control) StdoutLine: {'line': b'3: +\n'}
[11.490294] (control) StdoutLine: {'line': b'3: +      // Calculate target velocity in BODY frame (lateral strafe)\n'}
[11.490337] (control) StdoutLine: {'line': b'3: +      // BUG FIX: Removed negative sign - it was causing drone to move away from center!\n'}
[11.490378] (control) StdoutLine: {'line': b'3: +      // In body frame: X=forward, Y=left, Z=up\n'}
[11.490419] (control) StdoutLine: {'line': b'3: +      // Positive offset = gate is LEFT, need positive Y velocity (strafe left)\n'}
[11.490459] (control) StdoutLine: {'line': b'3: +      // Negative offset = gate is RIGHT, need negative Y velocity (strafe right)\n'}
[11.490500] (control) StdoutLine: {'line': b'3: +      // Proportional control: velocity proportional to offset\n'}
[11.490540] (control) StdoutLine: {'line': b'3: +      float target_velocity_body_y = proportional_gain * lateral_offset;        // \xe2\x9c\x85 FIXED: No negative sign!\n'}
[11.490581] (control) StdoutLine: {'line': b'3: +\n'}
[11.490621] (control) StdoutLine: {'line': b'3: +      // Limit velocity\n'}
[11.490661] (control) StdoutLine: {'line': b'3: +      target_velocity_body_y = std::max(\n'}
[11.490700] (control) StdoutLine: {'line': b'3: +        -max_velocity, std::min(\n'}
[11.490740] (control) StdoutLine: {'line': b'3: +          max_velocity,\n'}
[11.490780] (control) StdoutLine: {'line': b'3: +          target_velocity_body_y));\n'}
[11.490820] (control) StdoutLine: {'line': b'3: +\n'}
[11.490859] (control) StdoutLine: {'line': b'3: +      // Get current orientation for frame transformation\n'}
[11.490900] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();\n'}
[11.490940] (control) StdoutLine: {'line': b'3: +\n'}
[11.490980] (control) StdoutLine: {'line': b'3: +      // Extract yaw using getHeading helper function\n'}
[11.491018] (control) StdoutLine: {'line': b'3: +      float current_yaw = getHeading(current_pose.pose.orientation);\n'}
[11.491059] (control) StdoutLine: {'line': b'3: +\n'}
[11.491099] (control) StdoutLine: {'line': b'3: +      // Transform velocity from body frame to global frame\n'}
[11.491137] (control) StdoutLine: {'line': b'3: +      // Global frame transformation:\n'}
[11.491177] (control) StdoutLine: {'line': b'3: +      // vx_global = vx_body * cos(yaw) - vy_body * sin(yaw)\n'}
[11.491226] (control) StdoutLine: {'line': b'3: +      // vy_global = vx_body * sin(yaw) + vy_body * cos(yaw)\n'}
[11.491268] (control) StdoutLine: {'line': b'3: +      float vx_body = 0.0;        // No forward/backward in body frame\n'}
[11.491308] (control) StdoutLine: {'line': b'3: +      float vy_body = target_velocity_body_y;        // Lateral strafe in body frame\n'}
[11.491347] (control) StdoutLine: {'line': b'3: +\n'}
[11.491387] (control) StdoutLine: {'line': b'3: +      float vx_global = vx_body * cos(current_yaw) - vy_body * sin(current_yaw);\n'}
[11.491433] (control) StdoutLine: {'line': b'3: +      float vy_global = vx_body * sin(current_yaw) + vy_body * cos(current_yaw);\n'}
[11.491473] (control) StdoutLine: {'line': b'3: +\n'}
[11.491512] (control) StdoutLine: {'line': b'3: +      // Altitude control (global frame, Z is same in both frames)\n'}
[11.491552] (control) StdoutLine: {'line': b'3: +      float altitude_error = initial_z - current_pose.pose.position.z;\n'}
[11.491593] (control) StdoutLine: {'line': b'3: +      float target_velocity_z = 0.0;\n'}
[11.491634] (control) StdoutLine: {'line': b'3: +\n'}
[11.491674] (control) StdoutLine: {'line': b'3: +      // Gentle altitude correction\n'}
[11.491715] (control) StdoutLine: {'line': b'3: +      if (fabs(altitude_error) > 0.1) {\n'}
[11.491753] (control) StdoutLine: {'line': b'3: +        target_velocity_z = 0.3 * altitude_error;         // Gentle proportional control\n'}
[11.491792] (control) StdoutLine: {'line': b'3: +        target_velocity_z = std::max(-0.2f, std::min(0.2f, target_velocity_z));         // Limit to \xc2\xb10.2 m/s\n'}
[11.491832] (control) StdoutLine: {'line': b'3: +      }\n'}
[11.491872] (control) StdoutLine: {'line': b'3: +\n'}
[11.491911] (control) StdoutLine: {'line': b'3: +      // Publish velocity command in GLOBAL frame (map/odom frame)\n'}
[11.491958] (control) StdoutLine: {'line': b'3: +      geometry_msgs::msg::TwistStamped vel_cmd;\n'}
[11.491997] (control) StdoutLine: {'line': b'3: +      vel_cmd.header.stamp = node->now();\n'}
[11.492036] (control) StdoutLine: {'line': b'3: +      vel_cmd.header.frame_id = "map";       // Global frame for correct orientation\n'}
[11.492076] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.linear.x = vx_global;        // Global X velocity\n'}
[11.492116] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.linear.y = vy_global;        // Global Y velocity (transformed from body lateral)\n'}
[11.492156] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.linear.z = target_velocity_z;        // Altitude hold\n'}
[11.492196] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.angular.x = 0.0;\n'}
[11.492247] (control) StdoutLine: {'line': b'3: +      vel_cmd.twist.angular.y = 0.0;\n'}
