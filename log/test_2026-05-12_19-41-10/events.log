[11.462104] (control) StdoutLine: {'line': b'3: -        }\n'}
[11.462143] (control) StdoutLine: {'line': b'3: -        \n'}
[11.462181] (control) StdoutLine: {'line': b'3: -        // Calculate positions in Cartesian coordinates (body frame)\n'}
[11.462227] (control) StdoutLine: {'line': b'3: -        float left_x = left_dist * cos(left_angle);\n'}
[11.462269] (control) StdoutLine: {'line': b'3: -        float left_y = left_dist * sin(left_angle);\n'}
[11.462309] (control) StdoutLine: {'line': b'3: -        float right_x = right_dist * cos(right_angle);\n'}
[11.462348] (control) StdoutLine: {'line': b'3: -        float right_y = right_dist * sin(right_angle);\n'}
[11.462387] (control) StdoutLine: {'line': b'3: -        \n'}
[11.462427] (control) StdoutLine: {'line': b'3: -        // Calculate center point of the gate\n'}
[11.462466] (control) StdoutLine: {'line': b'3: -        float center_x = (left_x + right_x) / 2.0;\n'}
[11.462506] (control) StdoutLine: {'line': b'3: -        float center_y = (left_y + right_y) / 2.0;\n'}
[11.462543] (control) StdoutLine: {'line': b'3: -        \n'}
[11.462583] (control) StdoutLine: {'line': b'3: -        // The lateral offset (positive = gate center is to the LEFT)\n'}
[11.462622] (control) StdoutLine: {'line': b'3: -        float lateral_offset = center_y;\n'}
[11.462662] (control) StdoutLine: {'line': b'3: -        \n'}
[11.462701] (control) StdoutLine: {'line': b'3: -        RCLCPP_INFO_THROTTLE(node->get_logger(), *node->get_clock(), 500,\n'}
[11.462741] (control) StdoutLine: {'line': b'3: -                   "Gate center offset: %.3f m (forward: %.2f m)", lateral_offset, center_x);\n'}
[11.462783] (control) StdoutLine: {'line': b'3: -        \n'}
[11.462820] (control) StdoutLine: {'line': b"3: -        // Check if we're centered\n"}
