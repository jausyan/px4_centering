[11.481479] (control) StdoutLine: {'line': b'3: -            \n'}
[11.481520] (control) StdoutLine: {'line': b'3: -            RCLCPP_INFO_THROTTLE(node->get_logger(), *node->get_clock(), 500,\n'}
[11.481560] (control) StdoutLine: {'line': b'3: -                       "Centered, waiting for stability... (%d/%d)", \n'}
[11.481600] (control) StdoutLine: {'line': b'3: -                       consecutive_centered_count, required_consecutive);\n'}
[11.481640] (control) StdoutLine: {'line': b'3: -        } else {\n'}
[11.481680] (control) StdoutLine: {'line': b'3: -            // Not centered, reset counter\n'}
[11.481721] (control) StdoutLine: {'line': b'3: -            consecutive_centered_count = 0;\n'}
[11.481764] (control) StdoutLine: {'line': b'3: -            \n'}
[11.481803] (control) StdoutLine: {'line': b'3: -            // Calculate target velocity in BODY frame (lateral strafe)\n'}
[11.481843] (control) StdoutLine: {'line': b'3: -            // BUG FIX: Removed negative sign - it was causing drone to move away from center!\n'}
[11.481884] (control) StdoutLine: {'line': b'3: -            // In body frame: X=forward, Y=left, Z=up\n'}
[11.481924] (control) StdoutLine: {'line': b'3: -            // Positive offset = gate is LEFT, need positive Y velocity (strafe left)\n'}
[11.481964] (control) StdoutLine: {'line': b'3: -            // Negative offset = gate is RIGHT, need negative Y velocity (strafe right)\n'}
[11.482004] (control) StdoutLine: {'line': b'3: -            // Proportional control: velocity proportional to offset\n'}
[11.482042] (control) StdoutLine: {'line': b'3: -            float target_velocity_body_y = proportional_gain * lateral_offset;  // \xe2\x9c\x85 FIXED: No negative sign!\n'}
[11.482086] (control) StdoutLine: {'line': b'3: -            \n'}
[11.482126] (control) StdoutLine: {'line': b'3: -            // Limit velocity\n'}
[11.482165] (control) StdoutLine: {'line': b'3: -            target_velocity_body_y = std::max(-max_velocity, std::min(max_velocity, target_velocity_body_y));\n'}
[11.482205] (control) StdoutLine: {'line': b'3: -            \n'}
[11.482258] (control) StdoutLine: {'line': b'3: -            // Get current orientation for frame transformation\n'}
[11.482298] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();\n'}
[11.482339] (control) StdoutLine: {'line': b'3: -            \n'}
