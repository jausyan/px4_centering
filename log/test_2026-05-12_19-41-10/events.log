[11.476933] (control) StdoutLine: {'line': b'3: -    /**\n'}
[11.476973] (control) StdoutLine: {'line': b'3: -     * Center the drone to the NEAREST FORWARD GATE using 2D lidar with VELOCITY CONTROL\n'}
[11.477014] (control) StdoutLine: {'line': b'3: -     * \n'}
[11.477052] (control) StdoutLine: {'line': b'3: -     * NEW STRATEGY for multiple gates scenario:\n'}
[11.477092] (control) StdoutLine: {'line': b'3: -     * - Prioritizes gate directly in front (best forward alignment)\n'}
[11.477134] (control) StdoutLine: {'line': b'3: -     * - Filters out gates that are too far to the side\n'}
[11.477175] (control) StdoutLine: {'line': b'3: -     * - Uses forward zone filtering to ignore side/back obstacles\n'}
[11.477218] (control) StdoutLine: {'line': b'3: -     * \n'}
[11.477261] (control) StdoutLine: {'line': b'3: -     * This version uses proportional velocity control for smooth, gradual centering\n'}
[11.477301] (control) StdoutLine: {'line': b'3: -     * \n'}
[11.477342] (control) StdoutLine: {'line': b'3: -     * Strategy:\n'}
[11.477380] (control) StdoutLine: {'line': b'3: -     * 1. Detect NEAREST FORWARD gate posts using enhanced detection algorithm\n'}
[11.477421] (control) StdoutLine: {'line': b'3: -     * 2. Calculate lateral offset from gate center\n'}
[11.477459] (control) StdoutLine: {'line': b'3: -     * 3. Calculate proportional velocity based on offset\n'}
[11.477498] (control) StdoutLine: {'line': b'3: -     * 4. Publish velocity command continuously\n'}
[11.477536] (control) StdoutLine: {'line': b'3: -     * 5. When centered, stop and hold position\n'}
[11.477576] (control) StdoutLine: {'line': b'3: -     * \n'}
[11.477614] (control) StdoutLine: {'line': b'3: -     * Parameters:\n'}
[11.477653] (control) StdoutLine: {'line': b'3: -     * - forward_zone_min: Minimum forward distance to consider (default 0.5m)\n'}
[11.477693] (control) StdoutLine: {'line': b'3: -     * - max_lateral_angle: Max angle to gate center (default 45\xc2\xb0 = 0.785 rad)\n'}
[11.477734] (control) StdoutLine: {'line': b'3: -     */\n'}
[11.477771] (control) StdoutLine: {'line': b'3: -    \n'}
[11.477810] (control) StdoutLine: {'line': b'3: -    RCLCPP_INFO(node->get_logger(), "Starting NEAREST FORWARD gate centering (gate width: %.2f m, tolerance: %.2f m)...", gate_width, tolerance);\n'}
[11.477851] (control) StdoutLine: {'line': b'3: -    RCLCPP_INFO(node->get_logger(), "Forward zone min: %.2f m, Max lateral angle: %.2f\xc2\xb0", \n'}
[11.477889] (control) StdoutLine: {'line': b'3: -               forward_zone_min, max_lateral_angle * 180.0 / M_PI);\n'}
[11.477931] (control) StdoutLine: {'line': b'3: -    RCLCPP_INFO(node->get_logger(), "Max velocity: %.2f m/s, Proportional gain: %.2f", max_velocity, proportional_gain);\n'}
[11.477970] (control) StdoutLine: {'line': b'3: -    \n'}
[11.478009] (control) StdoutLine: {'line': b'3: -    auto start_time = node->now();\n'}
[11.478048] (control) StdoutLine: {'line': b'3: -    status = false;\n'}
[11.478087] (control) StdoutLine: {'line': b'3: -    \n'}
[11.478126] (control) StdoutLine: {'line': b'3: -    int consecutive_centered_count = 0;\n'}
[11.478164] (control) StdoutLine: {'line': b'3: -    int required_consecutive = 5; // Require 5 consecutive "centered" readings for stability (0.5 sec at 10Hz)\n'}
[11.478203] (control) StdoutLine: {'line': b'3: -    \n'}
[11.478251] (control) StdoutLine: {'line': b'3: -    // Get initial position for reference\n'}
[11.478292] (control) StdoutLine: {'line': b'3: -    geometry_msgs::msg::PoseStamped initial_pose = node->getCurrentLocalPose();\n'}
[11.478333] (control) StdoutLine: {'line': b'3: -    float initial_z = initial_pose.pose.position.z;\n'}
[11.478372] (control) StdoutLine: {'line': b'3: -    \n'}
[11.478411] (control) StdoutLine: {'line': b'3: -    while (rclcpp::ok()) {\n'}
[11.478451] (control) StdoutLine: {'line': b'3: -        // Check timeout\n'}
[11.478490] (control) StdoutLine: {'line': b'3: -        if ((node->now() - start_time).seconds() > max_time) {\n'}
[11.478530] (control) StdoutLine: {'line': b'3: -            RCLCPP_WARN(node->get_logger(), "Gate centering timeout after %.1f seconds", max_time);\n'}
[11.478569] (control) StdoutLine: {'line': b'3: -            \n'}
[11.478608] (control) StdoutLine: {'line': b'3: -            // Stop the drone (global frame)\n'}
[11.478647] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.478686] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.stamp = node->now();\n'}
[11.478724] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.frame_id = "map"; // Global frame\n'}
[11.478764] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.x = 0.0;\n'}
[11.478802] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.y = 0.0;\n'}
[11.478842] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.z = 0.0;\n'}
[11.478882] (control) StdoutLine: {'line': b'3: -            node->publishLocalVelocity(stop_cmd);\n'}
[11.478921] (control) StdoutLine: {'line': b'3: -            \n'}
[11.478960] (control) StdoutLine: {'line': b'3: -            status = false;\n'}
[11.478999] (control) StdoutLine: {'line': b'3: -            return;\n'}
[11.479038] (control) StdoutLine: {'line': b'3: -        }\n'}
[11.479077] (control) StdoutLine: {'line': b'3: -        \n'}
[11.479116] (control) StdoutLine: {'line': b'3: -        // Detect NEAREST FORWARD gate posts using enhanced algorithm\n'}
[11.479155] (control) StdoutLine: {'line': b'3: -        float left_angle, right_angle, left_dist, right_dist;\n'}
[11.479196] (control) StdoutLine: {'line': b'3: -        if (!detectGatePostsNear(node, left_angle, right_angle, left_dist, right_dist, \n'}
[11.479243] (control) StdoutLine: {'line': b'3: -                                 gate_width, 10.0, forward_zone_min, max_lateral_angle)) {\n'}
[11.479285] (control) StdoutLine: {'line': b'3: -            RCLCPP_WARN_THROTTLE(node->get_logger(), *node->get_clock(), 2000,\n'}
[11.479326] (control) StdoutLine: {'line': b'3: -                               "Nearest forward gate not detected, stopping movement...");\n'}
[11.479367] (control) StdoutLine: {'line': b'3: -            \n'}
[11.479407] (control) StdoutLine: {'line': b'3: -            // Stop the drone if gate is lost (global frame)\n'}
[11.479447] (control) StdoutLine: {'line': b'3: -            geometry_msgs::msg::TwistStamped stop_cmd;\n'}
[11.479488] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.stamp = node->now();\n'}
[11.479533] (control) StdoutLine: {'line': b'3: -            stop_cmd.header.frame_id = "map"; // Global frame\n'}
[11.479575] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.x = 0.0;\n'}
[11.479615] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.y = 0.0;\n'}
[11.479654] (control) StdoutLine: {'line': b'3: -            stop_cmd.twist.linear.z = 0.0;\n'}
[11.479693] (control) StdoutLine: {'line': b'3: -            node->publishLocalVelocity(stop_cmd);\n'}
[11.479734] (control) StdoutLine: {'line': b'3: -            \n'}
[11.479777] (control) StdoutLine: {'line': b'3: -            consecutive_centered_count = 0;\n'}
[11.479817] (control) StdoutLine: {'line': b'3: -            rclcpp::spin_some(node);\n'}
[11.479857] (control) StdoutLine: {'line': b'3: -            rate.sleep();\n'}
[11.479898] (control) StdoutLine: {'line': b'3: -            continue;\n'}
[11.479937] (control) StdoutLine: {'line': b'3: -        }\n'}
[11.479977] (control) StdoutLine: {'line': b'3: -        \n'}
[11.480016] (control) StdoutLine: {'line': b'3: -        // Calculate positions in Cartesian coordinates (body frame)\n'}
[11.480056] (control) StdoutLine: {'line': b'3: -        float left_x = left_dist * cos(left_angle);\n'}
[11.480094] (control) StdoutLine: {'line': b'3: -        float left_y = left_dist * sin(left_angle);\n'}
[11.480133] (control) StdoutLine: {'line': b'3: -        float right_x = right_dist * cos(right_angle);\n'}
[11.480172] (control) StdoutLine: {'line': b'3: -        float right_y = right_dist * sin(right_angle);\n'}
[11.480218] (control) StdoutLine: {'line': b'3: -        \n'}
[11.480262] (control) StdoutLine: {'line': b'3: -        // Calculate center point of the gate\n'}
[11.480303] (control) StdoutLine: {'line': b'3: -        float center_x = (left_x + right_x) / 2.0;\n'}
[11.480342] (control) StdoutLine: {'line': b'3: -        float center_y = (left_y + right_y) / 2.0;\n'}
[11.480381] (control) StdoutLine: {'line': b'3: -        \n'}
[11.480420] (control) StdoutLine: {'line': b'3: -        // The lateral offset (positive = gate center is to the LEFT)\n'}
[11.480461] (control) StdoutLine: {'line': b'3: -        float lateral_offset = center_y;\n'}
[11.480502] (control) StdoutLine: {'line': b'3: -        \n'}
[11.480542] (control) StdoutLine: {'line': b'3: -        RCLCPP_INFO_THROTTLE(node->get_logger(), *node->get_clock(), 500,\n'}
[11.480583] (control) StdoutLine: {'line': b'3: -                   "Nearest gate center offset: %.3f m (forward: %.2f m)", lateral_offset, center_x);\n'}
[11.480623] (control) StdoutLine: {'line': b'3: -        \n'}
[11.480662] (control) StdoutLine: {'line': b"3: -        // Check if we're centered\n"}
[11.480702] (control) StdoutLine: {'line': b'3: -        if (fabs(lateral_offset) < tolerance) {\n'}
