[11.322514] (control) StdoutLine: {'line': b'3: +  while (rclcpp::ok()) {\n'}
[11.322555] (control) StdoutLine: {'line': b'3: +    double dlat = raw.latitude - node->getCurrentGPSPosition().latitude;\n'}
[11.322596] (control) StdoutLine: {'line': b'3: +    double dlon = raw.longitude - node->getCurrentGPSPosition().longitude;\n'}
