3: +        node->get_logger(), *node->get_clock(), 2000,
3: +        "Nearest forward gate not detected, stopping movement...");
3: +
3: +      // Stop the drone if gate is lost (global frame)
3: +      geometry_msgs::msg::TwistStamped stop_cmd;
