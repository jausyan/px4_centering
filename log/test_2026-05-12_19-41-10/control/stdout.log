3: +  float target_yaw = current_yaw + rotation_angle;
3: +
3: +  // Normalize to [-pi, pi]
3: +  while (target_yaw > M_PI) {target_yaw -= 2.0 * M_PI;}
3: +  while (target_yaw < -M_PI) {target_yaw += 2.0 * M_PI;}
3: +
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Rotating from %.2f degrees to %.2f degrees",
3: +    current_yaw * 180.0 / M_PI, target_yaw * 180.0 / M_PI);
3: +
3: +  // Keep position the same, only change orientation
3: +  target_pose.pose.position = current_pose.pose.position;
3: +  setHeading(target_pose.pose.orientation, target_yaw);
3: +  target_pose.header.stamp = node->now();
3: +  target_pose.header.frame_id = "map";
3: +
3: +  // Rotation tolerance (5 degrees in radians)
