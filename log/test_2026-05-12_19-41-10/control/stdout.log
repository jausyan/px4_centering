3: +      // Get current pose
3: +      geometry_msgs::msg::PoseStamped last_drone_nonzero_pose = node->getDroneNonZeroPosePayload();
3: +
3: +      // Get current payload pose in local frame
3: +      geometry_msgs::msg::PoseStamped payload_pose = node->getLastNonZeroPosePayload();
3: +      error = -node->getLastNonZeroPosePayload().pose.position;
3: +      error = reflect(error);
3: +      speed_local = point_rotation_by_quaternion(error, last_drone_nonzero_pose.pose.orientation);
3: +
3: +      geometry_msgs::msg::PoseStamped payload_local_frame = last_drone_nonzero_pose;
3: +      payload_local_frame.pose.position.x = last_drone_nonzero_pose.pose.position.x + speed_local.x;
3: +      payload_local_frame.pose.position.y = last_drone_nonzero_pose.pose.position.y + speed_local.y;
3: +
3: +      moveToPoint(node, rate, posee, payload_local_frame.pose, 0.25, acc * 2.0);
3: +    } else {
3: +      RCLCPP_INFO(node->get_logger(), "Kayaknya ini payload nya kemajuan, coba maju dikit ya...");
3: +
3: +      geometry_msgs::msg::PoseStamped curr_pose = node->getCurrentLocalPose();
3: +      geometry_msgs::msg::Point maju;
3: +      float heading = getHeading(curr_pose.pose.orientation);
3: +      maju.x = x;
3: +      maju.y = y;
3: +      maju = rotatePoint(maju, heading);
