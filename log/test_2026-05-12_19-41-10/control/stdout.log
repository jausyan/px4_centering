3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +
3: +    if (payloadDetected(node) && allow_centering_payload) {
3: +      RCLCPP_INFO(node->get_logger(), "Payload Spotted");
3: +      geometry_msgs::msg::TwistStamped vel;
3: +      vel = zero(vel);
3: +      node->publishLocalVelocity(vel);
3: +      rclcpp::spin_some(node); rate.sleep();
3: +      break;
3: +    }
3: +    if (emberDetected(node) && allow_centering_ember) {
3: +      RCLCPP_INFO(node->get_logger(), "Ember Spotted");
3: +      geometry_msgs::msg::TwistStamped vel;
3: +      vel = zero(vel);
3: +      node->publishLocalVelocity(vel);
3: +      rclcpp::spin_some(node); rate.sleep();
3: +      break;
3: +    }
3: +  }
3: +
3: +  RCLCPP_INFO(node->get_logger(), "NYAMPEEEE");
3: +  geometry_msgs::msg::TwistStamped vel;
3: +  vel = zero(vel);
3: +  node->publishLocalVelocity(vel);
3: +  rclcpp::spin_some(node); rate.sleep();
3: +  posee = node->getCurrentLocalPose();
3: +}
