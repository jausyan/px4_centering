3: +void landingFauxPose(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee)
3: +{
3: +  /**
3: +   * Descend the drone to a lower altitude using a faux pose method.
3: +   * This method is used to land the drone by gradually decreasing its altitude.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   *
3: +   * returns:
3: +   * - posee: reference to the geometry_msgs::msg::PoseStamped object representing the current pose of the drone.
3: +   */
3: +  RCLCPP_INFO(node->get_logger(), "===================== Turun ====================");
3: +
3: +  geometry_msgs::msg::PoseStamped pose = posee;
3: +
3: +  float descend_speed = 0.4;
3: +  bool was_descending = false, trying_descending = false;
3: +
3: +  while (rclcpp::ok()) {
3: +    pose.pose.position.x = posee.pose.position.x;
3: +    pose.pose.position.y = posee.pose.position.y;
3: +    pose.pose.position.z -= descend_speed / RATE;
3: +    node->publishLocalPosition(pose);
3: +
3: +    if (node->getCurrentVelocity().twist.linear.z < -0.05 && !trying_descending) {
3: +      RCLCPP_INFO(node->get_logger(), "Descending..."); trying_descending = true;
3: +    }
3: +    if (node->getCurrentVelocity().twist.linear.z < -0.3) {was_descending = true;}
3: +    if (abs(node->getCurrentVelocity().twist.linear.z) < 0.05 && was_descending) {
3: +      RCLCPP_INFO(node->get_logger(), "Landed"); posee = node->getCurrentLocalPose(); break;
3: +    }
3: +
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +  }
3: +}
3: +
3: +void holdPosition(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float duration)
3: +{
3: +  /**
3: +   * Hold current position for a specified duration.
3: +   * For PX4 OFFBOARD mode: MUST continuously stream setpoints at high rate
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   * - duration: float value representing the duration in seconds to hold the position.
3: +   */
3: +  RCLCPP_INFO(node->get_logger(), "Holding position for %.1f seconds...", duration);
3: +
3: +  rclcpp::Time start_time = node->now();
3: +  rclcpp::Rate fast_rate(20.0);   // 20Hz for PX4 OFFBOARD
3: +
3: +  // Get current position to hold
3: +  geometry_msgs::msg::PoseStamped hold_pose = node->getCurrentLocalPose();
3: +
3: +  while (rclcpp::ok()) {
3: +    rclcpp::Time current_time = node->now();
3: +    double elapsed_time = (current_time - start_time).seconds();
3: +
3: +    // PX4 CRITICAL: Must stream setpoint continuously
3: +    hold_pose.header.stamp = node->now();
3: +    node->publishLocalPosition(hold_pose);
3: +
3: +    if (fmod(elapsed_time, 1.0) < 0.05) {     // Log every ~1 second
3: +      RCLCPP_INFO(node->get_logger(), "Holding... %.1f/%.1f seconds", elapsed_time, duration);
3: +    }
3: +
3: +    if (elapsed_time > duration) {break;}
3: +
3: +    rclcpp::spin_some(node);
3: +    fast_rate.sleep();     // Use fast rate for continuous streaming
3: +  }
3: +
3: +  RCLCPP_INFO(node->get_logger(), "Hold position complete");
3: +  posee = node->getCurrentLocalPose();
3: +}
3: +
3: +void waitForPosition(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  mavros_msgs::msg::GlobalPositionTarget raw, double tolerance,
3: +  bool allow_centering, float center_dist)
3: +{
3: +  /**
3: +   * Wait until the drone reaches a specified global position by checking the distance to the target position. Used when the drone moves using waypoint in AUTO mode.
3: +   * (Although its probably better to listen to mavlink's current_wp). see: https://mavlink.io/en/messages/common.html#MISSION_ITEM_REACHED
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate
3: +   * - raw: mavros_msgs::msg::GlobalPositionTarget object containing the target global position.
3: +   * - tolerance: double value representing the tolerance for reaching the target position in degrees.
3: +   * - allow_centering: boolean value indicating whether to allow centering the drone based on the payload position.
3: +   * - center_dist: float value representing the distance in meters to center the drone based on the payload position. (Not used for now)
3: +   */
3: +  sensor_msgs::msg::NavSatFix init_global = node->getCurrentGPSPosition();
3: +
3: +  while (rclcpp::ok()) {
3: +    double dlat = raw.latitude - node->getCurrentGPSPosition().latitude;
3: +    double dlon = raw.longitude - node->getCurrentGPSPosition().longitude;
3: +    double dalt = raw.altitude - node->getCurrentGPSPosition().altitude;
3: +
3: +    double distance = std::sqrt(dlat * dlat + dlon * dlon);
3: +    double dist_m = latLonToMeter(
3: +      init_global.latitude, init_global.longitude,
3: +      node->getCurrentGPSPosition().latitude, node->getCurrentGPSPosition().longitude);
3: +
3: +    RCLCPP_INFO(
3: +      node->get_logger(), "%d - CURRR DISTANCEE: %f, meter: %.2f, payload: %.2f", distance, dist_m,
3: +      node->getCurrentPosePayload().pose.position.x);
3: +
3: +    if (distance < tolerance) {
3: +      RCLCPP_INFO(node->get_logger(), "Reached target positionnnn");
3: +      break;
3: +    }
3: +
3: +    if (payloadDetected(node) && allow_centering) {
3: +      RCLCPP_INFO(node->get_logger(), "Payload spotted");
3: +      // distancee_to_payload = sqrt((pose.pose.position.x - init_pose.pose.position.x) * (pose.pose.position.x - init_pose.pose.position.x) + (pose.pose.position.y - init_pose.pose.position.y) * (pose.pose.position.y - init_pose.pose.position.y));
3: +      break;
3: +    }
3: +
3: +    node->publishSetpointRawGlobal(raw);
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +  }
3: +}
3: +
3: +void sendGlobalRaw(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float latt, float lonn, float altt,
3: +  bool allow_centering, float center_dist, float tolerance)
3: +{
3: +  /**
3: +   * Send a raw global position target to the drone and wait until the drone reaches the target position.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate
3: +   * - latt: float value representing the target latitude in degrees.
3: +   * - lonn: float value representing the target longitude in degrees.
3: +   * - altt: float value representing the target altitude in meters.
3: +   * - allow_centering: boolean value indicating whether to allow centering the drone based on the payload position.
3: +   * - center_dist: float value representing the distance in meters to center the drone based on the payload position.
3: +   *
3: +   * returns:
3: +   * - posee: reference to the geometry_msgs::msg::PoseStamped object representing the current pose of the drone.
3: +   */
3: +  mavros_msgs::msg::GlobalPositionTarget raw;
3: +  raw.header.stamp = node->now();
3: +  raw.header.frame_id = "map";
3: +  raw.coordinate_frame = mavros_msgs::msg::GlobalPositionTarget::FRAME_GLOBAL_REL_ALT;
3: +  raw.type_mask =
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_VX |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_VY |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_VZ |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_AFX |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_AFY |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_AFZ |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_YAW |
3: +    mavros_msgs::msg::GlobalPositionTarget::IGNORE_YAW_RATE;
3: +
3: +  raw.latitude = latt;
3: +  raw.longitude = lonn;
3: +  raw.altitude = altt;
3: +
3: +  RCLCPP_INFO(node->get_logger(), "Sending target: [%.8f, %.8f, %.2f]", latt, lonn, altt);
3: +
3: +  for (int i = 0; i < 20; i++) {
3: +    node->publishSetpointRawGlobal(raw);
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +  }
3: +
3: +  waitForPosition(node, rate, raw, tolerance, allow_centering, center_dist);
3: +  // waitForPosition(node, rate, latt, lonn, altt, );
3: +
3: +  posee = node->getCurrentLocalPose();
3: +}
