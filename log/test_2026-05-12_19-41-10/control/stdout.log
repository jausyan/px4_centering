3: +
3: +void centeringGateLidar(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float gate_width,
3: +  float tolerance, bool & status, float max_time)
3: +{
3: +  /**
3: +   * Center the drone between two gate posts using 2D lidar
3: +   * Strategy:
3: +   * 1. Detect gate posts
3: +   * 2. Calculate center point between posts
3: +   * 3. Calculate offset from drone to center
3: +   * 4. Strafe to center position
3: +   * 5. Repeat until centered within tolerance
3: +   */
3: +
3: +  RCLCPP_INFO(
3: +    node->get_logger(),
3: +    "Centering Lidar ygy... (gate width: %.2f m, tolerance: %.2f m)...",
3: +    gate_width, tolerance);
3: +
3: +  auto start_time = node->now();
3: +  status = false;
3: +
3: +  int consecutive_centered_count = 0;
3: +  int required_consecutive = 3;   // Require 3 consecutive "centered" readings for stability
3: +
3: +  while (rclcpp::ok()) {
3: +    // Check timeout
3: +    if ((node->now() - start_time).seconds() > max_time) {
3: +      RCLCPP_WARN(node->get_logger(), "Gate centering timeout after %.1f seconds", max_time);
3: +      status = false;
3: +      return;
3: +    }
3: +
3: +    // Detect gate posts
3: +    float left_angle, right_angle, left_dist, right_dist;
3: +    if (!detectGatePosts(node, left_angle, right_angle, left_dist, right_dist, gate_width)) {
3: +      RCLCPP_WARN_THROTTLE(
3: +        node->get_logger(), *node->get_clock(), 2000,
3: +        "Gate tidak kedetek, retrying...");
3: +      consecutive_centered_count = 0;
3: +      rclcpp::spin_some(node);
3: +      rate.sleep();
3: +      continue;
3: +    }
3: +
3: +    // Calculate positions in Cartesian coordinates (body frame)
3: +    float left_x = left_dist * cos(left_angle);
3: +    float left_y = left_dist * sin(left_angle);
3: +    float right_x = right_dist * cos(right_angle);
3: +    float right_y = right_dist * sin(right_angle);
3: +
3: +    // Calculate center point of the gate
3: +    float center_x = (left_x + right_x) / 2.0;
3: +    float center_y = (left_y + right_y) / 2.0;
3: +
3: +    // The offset we need to move is just the Y component (lateral offset)
3: +    // Positive center_y means gate center is to the LEFT, so we need to strafe LEFT
3: +    // Negative center_y means gate center is to the RIGHT, so we need to strafe RIGHT
3: +    float lateral_offset = center_y;
3: +
3: +    RCLCPP_INFO(
3: +      node->get_logger(),
3: +      "offset center gate: %.3f m (forward: %.2f m, lateral: %.2f m)",
3: +      lateral_offset, center_x, center_y);
3: +
3: +    // Check if we're centered
3: +    if (fabs(lateral_offset) < tolerance) {
3: +      consecutive_centered_count++;
3: +      RCLCPP_INFO(
3: +        node->get_logger(),
3: +        "Centered! (%.3f m offset, %d/%d consecutive)",
3: +        lateral_offset, consecutive_centered_count, required_consecutive);
3: +
3: +      if (consecutive_centered_count >= required_consecutive) {
3: +        RCLCPP_INFO(node->get_logger(), "Gate centering successful!");
3: +        status = true;
3: +        posee = node->getCurrentLocalPose();
3: +        return;
3: +      }
3: +    } else {
3: +      consecutive_centered_count = 0;
3: +
3: +      // Calculate strafe distance (limit to prevent overshooting)
3: +      float max_strafe_per_iteration = 0.3;       // Maximum 30cm per iteration
3: +      float strafe_distance = lateral_offset;
3: +
3: +      if (fabs(strafe_distance) > max_strafe_per_iteration) {
3: +        strafe_distance =
3: +          (strafe_distance > 0) ? max_strafe_per_iteration : -max_strafe_per_iteration;
3: +      }
3: +
3: +      // Strafe to center
3: +      // Positive offset = gate is to the left, strafe left (positive y)
3: +      // Negative offset = gate is to the right, strafe right (negative y)
3: +      RCLCPP_INFO(node->get_logger(), "Strafing %.3f m to center...", strafe_distance);
3: +
3: +      executeLocalWaypointMove(node, rate, posee, 0.0, strafe_distance, 0.0, 0.0, 0.1);
3: +    }
3: +
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +  }
3: +
3: +  status = false;
3: +}
3: +
3: +void centeringGateLidarVelocity(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float gate_width,
3: +  float tolerance, bool & status, float max_velocity,
3: +  float proportional_gain, float max_time)
3: +{
3: +  /**
3: +   * Center the drone between two gate posts using 2D lidar with VELOCITY CONTROL
3: +   * This version uses proportional velocity control for smooth, gradual centering
3: +   *
3: +   * Strategy:
3: +   * 1. Detect gate posts using lidar
3: +   * 2. Calculate lateral offset from gate center
3: +   * 3. Calculate proportional velocity based on offset
3: +   * 4. Publish velocity command continuously
3: +   * 5. When centered, stop and hold position
3: +   *
3: +   * Advantages over position control:
3: +   * - Smooth, continuous movement (no jerky steps)
3: +   * - Automatic deceleration as approaching center
3: +   * - Better safety with explicit velocity limiting
3: +   * - Real-time feedback and correction
3: +   */
3: +
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Velocity Control Lidar Centering Start ygy... (gate width: %.2f m, tolerance: %.2f m)...", gate_width,
3: +    tolerance);
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Max velocity: %.2f m/s, Proportional gain: %.2f", max_velocity,
3: +    proportional_gain);
3: +
3: +  auto start_time = node->now();
3: +  status = false;
3: +
3: +  int consecutive_centered_count = 0;
3: +  int required_consecutive = 5;   // Require 5 consecutive "centered" readings for stability (0.5 sec at 10Hz)
3: +
3: +  // Get initial position for reference
3: +  geometry_msgs::msg::PoseStamped initial_pose = node->getCurrentLocalPose();
3: +  float initial_z = initial_pose.pose.position.z;
3: +
3: +  while (rclcpp::ok()) {
3: +    // Check timeout
3: +    if ((node->now() - start_time).seconds() > max_time) {
3: +      RCLCPP_WARN(node->get_logger(), "Gate centering timeout after %.1f seconds", max_time);
3: +
3: +      // Stop the drone (global frame)
3: +      geometry_msgs::msg::TwistStamped stop_cmd;
3: +      stop_cmd.header.stamp = node->now();
3: +      stop_cmd.header.frame_id = "map";       // Global frame
3: +      stop_cmd.twist.linear.x = 0.0;
3: +      stop_cmd.twist.linear.y = 0.0;
3: +      stop_cmd.twist.linear.z = 0.0;
3: +      node->publishLocalVelocity(stop_cmd);
3: +
3: +      status = false;
3: +      return;
3: +    }
3: +
3: +    // Detect gate posts
3: +    float left_angle, right_angle, left_dist, right_dist;
3: +    if (!detectGatePosts(node, left_angle, right_angle, left_dist, right_dist, gate_width)) {
