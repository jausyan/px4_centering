3: +
3: +void correctAltitude(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, double height,
3: +  float & corrected_rel_alt, double max_speed)
3: +{
3: +  /**
3: +   * Correct the drone's altitude to a specified rangefinder reading by adjusting its velocity.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   * - vel_pub: shared pointer to the rclcpp::Publisher for publishing velocity commands.
3: +   * - height: double value representing the target altitude in meters.
3: +   *
3: +   * returns:
3: +   * - posee: reference to the geometry_msgs::msg::PoseStamped object representing the current pose of the drone.
3: +   * - The correct relative altitude after adjusting the drone's position. ready to be used for sendGlobalRaw.
3: +   */
3: +  RCLCPP_INFO(node->get_logger(), "fixing altitude..");
3: +  geometry_msgs::msg::Twist cmd_vel = geometry_msgs::msg::Twist();
3: +  rclcpp::Time last_correct_time = rclcpp::Time(0, 0);
3: +  bool hit = false;
3: +
3: +  const float MAX_SPEED = max_speed;
3: +
3: +  const float P = 1.0;
3: +  const float I = 0.0;
3: +  const float D = 0.0;
3: +
3: +  float total_error = 0;
3: +  float last_error = 0;
3: +
3: +  while
3: +  (
3: +    !hit ||
3: +    (rclcpp::ok() && abs(node->getCurrentRangefinder().range - height) > 0.05) ||
3: +    (hit && node->now() - last_correct_time <= rclcpp::Duration::from_seconds(2.0))
3: +  )
3: +  {
3: +    total_error += height - node->getCurrentRangefinder().range;
3: +    cmd_vel.linear.x = 0.0;
3: +    cmd_vel.linear.y = 0.0;
3: +    cmd_vel.linear.z =
3: +      limit(
3: +      MAX_SPEED,
3: +      P * (height - node->getCurrentRangefinder().range) + I * (total_error) + D *
3: +      (last_error - (height - node->getCurrentRangefinder().range)));
3: +
3: +    RCLCPP_INFO(
3: +      node->get_logger(), "height: %f current_alt.range: %f", height,
3: +      node->getCurrentRangefinder().range);
3: +    last_error = (height - node->getCurrentRangefinder().range);
3: +    node->publishLocalVelocityUnstamped(cmd_vel);
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +
3: +    if (!(abs(node->getCurrentRangefinder().range - height) > 0.05) && !hit) {
3: +      last_correct_time = node->now();
3: +      hit = true;
3: +      RCLCPP_INFO(node->get_logger(), "HIT!, last_correct_time: %f", last_correct_time.seconds());
3: +    } else if ((abs(node->getCurrentRangefinder().range - height) > 0.05)) {
3: +      RCLCPP_INFO(node->get_logger(), "left the tolerance zone, resetting");
3: +      hit = false;
3: +    }
3: +
3: +  }
3: +  corrected_rel_alt = node->getCurrentRelAlt().data;
3: +  posee = node->getCurrentLocalPose();
3: +}
3: +
3: +void controlServo(const std::shared_ptr<DroneController> & node, int channel, int pwm)
3: +{
3: +  auto request = std::make_shared<mavros_msgs::srv::CommandLong::Request>();
3: +  // MAV_CMD_DO_SET_SERVO == 183
3: +  request->command = 183; request->param1 = channel; request->param2 = pwm;
3: +  request->param3 = 0; request->param4 = 0; request->param5 = 0; request->param6 = 0;
3: +  request->param7 = 0;
3: +
3: +  auto future_result = node->servo_(request);
3: +
3: +  if (hasReplied(node, future_result)) {
3: +    auto result = future_result.get();
3: +    if (result->success) {
3: +      RCLCPP_INFO(node->get_logger(), "Channel: %d servo signal sent", channel);
3: +    } else {RCLCPP_ERROR(node->get_logger(), "Servo signal failed.");}
3: +  } else {RCLCPP_ERROR(node->get_logger(), "Failed to receive response");}
3: +}
3: +
3: +void controlServoRepeated(
3: +  const std::shared_ptr<DroneController> & node, int channel, int pwm,
3: +  int repeat)
3: +{
3: +  for (int i = 0; i < repeat; ++i) {
3: +    controlServo(node, channel, pwm);
3: +  }
3: +}
3: +
3: +void pushMission(
3: +  const std::shared_ptr<DroneController> & node,
3: +  std::vector<mavros_msgs::msg::Waypoint> waypoints)
3: +{
3: +  waypoints.insert(waypoints.begin() + 0, waypoints[0]);   // I dont know why but the first waypoint is always skipped when pushing mission, so I duplicate it
3: +  RCLCPP_INFO(node->get_logger(), "Pushing mission of size %d", waypoints.size());
3: +  auto request = std::make_shared<mavros_msgs::srv::WaypointPush::Request>();
3: +  request->start_index = 0;
3: +  request->waypoints = waypoints;
3: +
3: +  auto future_result = node->pushMission_(request);
3: +
3: +  if (hasReplied(node, future_result)) {
3: +    auto result = future_result.get();
3: +    if (result->success) {RCLCPP_INFO(node->get_logger(), "Mission pushed");} else {
3: +      RCLCPP_ERROR(node->get_logger(), "failed to push mission");
3: +    }
3: +  } else {RCLCPP_ERROR(node->get_logger(), "Failed to receive response");}
3: +}
3: +
3: +void clearMission(const std::shared_ptr<DroneController> & node)
3: +{
3: +  auto request = std::make_shared<mavros_msgs::srv::WaypointClear::Request>();
3: +
3: +  auto future_result = node->clearMission_(request);
3: +
3: +  if (hasReplied(node, future_result)) {
3: +    auto result = future_result.get();
3: +    if (result->success) {
3: +      RCLCPP_INFO(node->get_logger(), "Mission cleared"); node->reset_wp_();
3: +    } else {RCLCPP_ERROR(node->get_logger(), "failed to clear mission");}
3: +  } else {RCLCPP_ERROR(node->get_logger(), "Failed to receive response");}
3: +}
3: +
3: +void waitForWP(const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate, int seq)
3: +{
3: +  while (rclcpp::ok()) {
3: +    if (node->current_wp_() >= seq) {
3: +      RCLCPP_INFO(node->get_logger(), "wp reached! :)");
3: +      break;
3: +    }
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +  }
3: +}
