3: +{
3: +  /**
3: +   * Center the drone to the NEAREST FORWARD GATE using 2D lidar with VELOCITY CONTROL
3: +   *
3: +   * NEW STRATEGY for multiple gates scenario:
3: +   * - Prioritizes gate directly in front (best forward alignment)
3: +   * - Filters out gates that are too far to the side
3: +   * - Uses forward zone filtering to ignore side/back obstacles
3: +   *
3: +   * This version uses proportional velocity control for smooth, gradual centering
3: +   *
3: +   * Strategy:
3: +   * 1. Detect NEAREST FORWARD gate posts using enhanced detection algorithm
3: +   * 2. Calculate lateral offset from gate center
3: +   * 3. Calculate proportional velocity based on offset
3: +   * 4. Publish velocity command continuously
3: +   * 5. When centered, stop and hold position
3: +   *
3: +   * Parameters:
3: +   * - forward_zone_min: Minimum forward distance to consider (default 0.5m)
3: +   * - max_lateral_angle: Max angle to gate center (default 45° = 0.785 rad)
3: +   */
3: +
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Starting NEAREST FORWARD gate centering (gate width: %.2f m, tolerance: %.2f m)...", gate_width,
3: +    tolerance);
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Forward zone min: %.2f m, Max lateral angle: %.2f°",
3: +    forward_zone_min, max_lateral_angle * 180.0 / M_PI);
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Max velocity: %.2f m/s, Proportional gain: %.2f", max_velocity,
3: +    proportional_gain);
3: +
3: +  auto start_time = node->now();
3: +  status = false;
3: +
3: +  int consecutive_centered_count = 0;
3: +  int required_consecutive = 5;   // Require 5 consecutive "centered" readings for stability (0.5 sec at 10Hz)
3: +
3: +  // Get initial position for reference
3: +  geometry_msgs::msg::PoseStamped initial_pose = node->getCurrentLocalPose();
3: +  float initial_z = initial_pose.pose.position.z;
3: +
3: +  while (rclcpp::ok()) {
3: +    // Check timeout
3: +    if ((node->now() - start_time).seconds() > max_time) {
3: +      RCLCPP_WARN(node->get_logger(), "Gate centering timeout after %.1f seconds", max_time);
3: +
3: +      // Stop the drone (global frame)
3: +      geometry_msgs::msg::TwistStamped stop_cmd;
3: +      stop_cmd.header.stamp = node->now();
3: +      stop_cmd.header.frame_id = "map";       // Global frame
3: +      stop_cmd.twist.linear.x = 0.0;
3: +      stop_cmd.twist.linear.y = 0.0;
3: +      stop_cmd.twist.linear.z = 0.0;
3: +      node->publishLocalVelocity(stop_cmd);
