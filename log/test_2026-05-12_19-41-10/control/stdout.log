3: +
3: +void centeringGate(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float acc)
3: +{
3: +  RCLCPP_INFO(node->get_logger(), "---------- Starting to center gate ----------");
3: +
3: +  while (rclcpp::ok()) {
3: +    sensor_msgs::msg::LaserScan curr_scan = node->getCurrentLaserScan();
3: +    geometry_msgs::msg::TwistStamped cmd_vel;
3: +    geometry_msgs::msg::Point vel_pose;
3: +    bool one_centroid_only = false;
3: +
3: +    // 1. Get points from polar coordinate (laserscan data) to cartesian coordinate
3: +    int quarter_size = curr_scan.ranges.size() / 4;
3: +    int left_count = 0; int right_count = 0;
3: +    std::vector<float> x_points;
3: +    std::vector<float> y_points;
3: +    RCLCPP_INFO(node->get_logger(), "LEFT: ");
3: +    for (int i = 0; i <= quarter_size; i++) {
3: +      float angle = M_PI / (2 * quarter_size) * i;
3: +      if (curr_scan.ranges[i] == std::numeric_limits<float>::infinity() ||
3: +        std::isnan(curr_scan.ranges[i]) || curr_scan.ranges[i] > 2.82843 ||
3: +        curr_scan.ranges[i] * cos(angle) < 0.4 || curr_scan.ranges[i] < 0.4)
3: +      {
3: +        continue;
3: +      }
3: +      x_points.push_back(curr_scan.ranges[i] * cos(angle));
3: +      y_points.push_back(curr_scan.ranges[i] * sin(angle));
3: +      RCLCPP_INFO(
3: +        node->get_logger(), "   - x: %f, y: %f, angle: %f",
3: +        curr_scan.ranges[i] * cos(angle), curr_scan.ranges[i] * sin(angle), angle);
3: +      left_count++;
3: +    }
3: +    RCLCPP_INFO(node->get_logger(), "RIGHT: ");
3: +    for (int i = 0; i <= quarter_size; i++) {
3: +      float angle = M_PI * 1.5 + (M_PI / (2 * quarter_size) * i);
3: +      if (curr_scan.ranges[3 * quarter_size + i] == std::numeric_limits<float>::infinity() ||
3: +        std::isnan(curr_scan.ranges[3 * quarter_size + i]) ||
3: +        curr_scan.ranges[3 * quarter_size + i] > 2.0 ||
3: +        curr_scan.ranges[3 * quarter_size + i] * cos(angle) < 0.4 ||
3: +        curr_scan.ranges[3 * quarter_size + i] < 0.4)
3: +      {
3: +        continue;
3: +      }
3: +      x_points.push_back(curr_scan.ranges[3 * quarter_size + i] * cos(angle));
3: +      y_points.push_back(curr_scan.ranges[3 * quarter_size + i] * sin(angle));
3: +      RCLCPP_INFO(
3: +        node->get_logger(), "   - x: %f, y: %f, angle: %f",
3: +        curr_scan.ranges[3 * quarter_size + i] * cos(
3: +          angle), curr_scan.ranges[3 * quarter_size + i] * sin(angle), angle);
3: +      right_count++;
3: +    }
3: +    if (x_points.size() < 2) {
3: +      RCLCPP_ERROR(node->get_logger(), "GOT NO POINTS FROM LIDAR DATA");
3: +      cmd_vel = zero(cmd_vel);
3: +      node->publishLocalVelocity(cmd_vel);
3: +      rclcpp::spin_some(node);
3: +      rate.sleep();
3: +      continue;
3: +    }
3: +
3: +    // 2. Do clustering with two centroid
3: +    int iteration = 50;
3: +    // float centroid1_x = 1.0, centroid1_y = 0.75, centroid2_x = 1.0, centroid2_y = -0.75;
3: +    float centroid1_x = *std::min_element(x_points.begin(), x_points.end()),
3: +      centroid1_y = *std::max_element(y_points.begin(), y_points.end()),
3: +      centroid2_x = *std::min_element(x_points.begin(), x_points.end()),
3: +      centroid2_y = *std::min_element(y_points.begin(), y_points.end());
3: +    int centroid1_member_size, centroid2_member_size;
3: +    float x1_min = -1.0, x2_min = -1.0;
