3: +{
3: +  /**
3: +   * Move the drone to a specified point in local coordinates with a given speed and angle.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   * - x: float value representing the target x-coordinate in local coordinates.
3: +   * - y: float value representing the target y-coordinate in local coordinates.
3: +   * - z: float value representing the target z-coordinate in local coordinates.
3: +   * - angle: float value representing the angle to turn towards in radians.
3: +   * - speed: float value representing the speed at which the drone should move.
3: +   *
3: +   * returns:moveToPoint
3: +   * - posee: reference to the geometry_msgs::msg::PoseStamped object representing the current pose of the drone.
3: +   */
3: +  // float last_x, last_y, distance, progress=0.0; int i =0;
3: +  geometry_msgs::msg::PoseStamped cmd_pose = node->getCurrentLocalPose();
3: +  cmd_pose.pose = target;
3: +
3: +  // last_x = cmd_pose.pose.position.x;
3: +  // last_y = cmd_pose.pose.position.y;
3: +  // distance = dist(cmd_pose.pose.position, target.position);
3: +  geometry_msgs::msg::PoseStamped curr_pose = node->getCurrentLocalPose();
3: +
3: +  float distance_to_target = dist(posee.pose.position, target.position);
3: +  float vel_z = (target.position.z - node->getCurrentRangefinder().range) / dist(
3: +    curr_pose.pose.position, target.position);
3: +  bool alt_reached = false;
3: +
3: +  while (rclcpp::ok() && !isNear(curr_pose.pose.position, target.position, tolerance)) {
3: +    float distance = dist(curr_pose.pose.position, target.position);
3: +    RCLCPP_INFO(node->get_logger(), "moving..., dist: %f", distance);
3: +    curr_pose = node->getCurrentLocalPose();
3: +
3: +    geometry_msgs::msg::TwistStamped vel;
3: +    vel.twist.linear.x = (target.position.x - curr_pose.pose.position.x);
3: +    vel.twist.linear.y = (target.position.y - curr_pose.pose.position.y);
3: +
3: +    vel = limit(speed, vel);
3: +    vel.twist.linear.z =
3: +      disable_z_lock ? (std::abs(target.position.z - node->getCurrentRangefinder().range) > 0.15 &&
