3: +      stop_cmd.header.frame_id = "map";
3: +      stop_cmd.twist.linear.x = 0.0;
3: +      stop_cmd.twist.linear.y = 0.0;
3: +      stop_cmd.twist.linear.z = 0.0;
3: +      node->publishLocalVelocity(stop_cmd);
3: +
3: +      if (consecutive_centered_count >= required_consecutive) {
3: +        RCLCPP_INFO(
3: +          node->get_logger(),
3: +          "Centered on nearest forward gate! (offset: %.3f m, consecutive: %d)",
3: +          lateral_offset, consecutive_centered_count);
3: +        status = true;
3: +        return;
3: +      }
3: +
3: +      RCLCPP_INFO_THROTTLE(
3: +        node->get_logger(), *node->get_clock(), 500,
3: +        "Centered, waiting for stability... (%d/%d)",
3: +        consecutive_centered_count, required_consecutive);
3: +    } else {
3: +      // Not centered, reset counter
3: +      consecutive_centered_count = 0;
3: +
3: +      // Calculate target velocity in BODY frame (lateral strafe)
3: +      // BUG FIX: Removed negative sign - it was causing drone to move away from center!
3: +      // In body frame: X=forward, Y=left, Z=up
3: +      // Positive offset = gate is LEFT, need positive Y velocity (strafe left)
3: +      // Negative offset = gate is RIGHT, need negative Y velocity (strafe right)
3: +      // Proportional control: velocity proportional to offset
3: +      float target_velocity_body_y = proportional_gain * lateral_offset;        // ✅ FIXED: No negative sign!
3: +
3: +      // Limit velocity
3: +      target_velocity_body_y = std::max(
3: +        -max_velocity, std::min(
3: +          max_velocity,
3: +          target_velocity_body_y));
3: +
3: +      // Get current orientation for frame transformation
3: +      geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();
3: +
3: +      // Extract yaw using getHeading helper function
3: +      float current_yaw = getHeading(current_pose.pose.orientation);
3: +
3: +      // Transform velocity from body frame to global frame
3: +      // Global frame transformation:
3: +      // vx_global = vx_body * cos(yaw) - vy_body * sin(yaw)
3: +      // vy_global = vx_body * sin(yaw) + vy_body * cos(yaw)
3: +      float vx_body = 0.0;        // No forward/backward in body frame
3: +      float vy_body = target_velocity_body_y;        // Lateral strafe in body frame
3: +
3: +      float vx_global = vx_body * cos(current_yaw) - vy_body * sin(current_yaw);
3: +      float vy_global = vx_body * sin(current_yaw) + vy_body * cos(current_yaw);
3: +
3: +      // Altitude control (global frame, Z is same in both frames)
3: +      float altitude_error = initial_z - current_pose.pose.position.z;
3: +      float target_velocity_z = 0.0;
3: +
3: +      // Gentle altitude correction
3: +      if (fabs(altitude_error) > 0.1) {
3: +        target_velocity_z = 0.3 * altitude_error;         // Gentle proportional control
3: +        target_velocity_z = std::max(-0.2f, std::min(0.2f, target_velocity_z));         // Limit to ±0.2 m/s
3: +      }
3: +
3: +      // Publish velocity command in GLOBAL frame (map/odom frame)
3: +      geometry_msgs::msg::TwistStamped vel_cmd;
3: +      vel_cmd.header.stamp = node->now();
3: +      vel_cmd.header.frame_id = "map";       // Global frame for correct orientation
3: +      vel_cmd.twist.linear.x = vx_global;        // Global X velocity
3: +      vel_cmd.twist.linear.y = vy_global;        // Global Y velocity (transformed from body lateral)
3: +      vel_cmd.twist.linear.z = target_velocity_z;        // Altitude hold
3: +      vel_cmd.twist.angular.x = 0.0;
3: +      vel_cmd.twist.angular.y = 0.0;
3: +      vel_cmd.twist.angular.z = 0.0;       // No rotation
3: +
3: +      node->publishLocalVelocity(vel_cmd);
3: +
3: +      RCLCPP_INFO_THROTTLE(
3: +        node->get_logger(), *node->get_clock(), 500,
3: +        "Body Y vel: %.3f m/s | Global vel: [%.3f, %.3f] m/s | Offset: %.3f m | Yaw: %.1f°",
3: +        vy_body, vx_global, vy_global, lateral_offset, current_yaw * 180.0 / M_PI);
3: +    }
3: +
3: +    rclcpp::spin_some(node);
3: +    rate.sleep();
3: +  }
3: +
3: +  // Final stop command
3: +  geometry_msgs::msg::TwistStamped stop_cmd;
