3: +  geometry_msgs::msg::PoseStamped & posee, float rotation_angle)
3: +{
3: +  /**
3: +   * Execute a rotation in place by publishing position commands with updated orientation
3: +   * Rotation is relative to current heading
3: +   *
3: +   * NOTE: This function uses RADIANS. For easier degree-based rotation, use rotateByDegrees() instead!
3: +   *
3: +   * PARAMETERS:
3: +   * - rotation_angle: angle in RADIANS
3: +   *   - Positive = RIGHT/Clockwise (e.g., +1.57 rad = 90° right)
3: +   *   - Negative = LEFT/Counter-clockwise (e.g., -1.57 rad = 90° left)
3: +   *
3: +   * EXAMPLES:
3: +   * - executeLocalWaypointRotation(node, rate, posee, M_PI/2);    // 90° right
3: +   * - executeLocalWaypointRotation(node, rate, posee, -M_PI/2);   // 90° left
3: +   * - executeLocalWaypointRotation(node, rate, posee, M_PI);      // 180° (U-turn)
3: +   */
3: +
3: +  // Get current pose
3: +  geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();
3: +  geometry_msgs::msg::PoseStamped target_pose = current_pose;
3: +
3: +  // Get current yaw angle
3: +  float current_yaw = getHeading(current_pose.pose.orientation);
3: +
