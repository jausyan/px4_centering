3: +void waitLand(const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate)
3: +{
3: +  /**
3: +   * Wait until the drone has landed by checking its altitude.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   */
3: +  while (rclcpp::ok() && node->getCurrentLocalPose().pose.position.z > 0.1) {
3: +    RCLCPP_INFO(
3: +      node->get_logger(), "current altitude: %f",
3: +      node->getCurrentLocalPose().pose.position.z);
3: +    rclcpp::spin_some(node); rate.sleep();
3: +  }
3: +}
