3: +void executeLocalWaypointMoveVelocity(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float forward_x, float left_y,
3: +  float up_z, float yaw_angle, float max_velocity, float tolerance)
3: +{
3: +  /**
3: +   * Execute a local waypoint movement using VELOCITY CONTROL for smooth, controlled movement
3: +   * Movement is relative to the current drone's heading (body frame)
3: +   *
3: +   * Unlike executeLocalWaypointMove() which uses position control and can cause sudden movements,
3: +   * this function sends velocity setpoints continuously at max_velocity for smooth motion.
3: +   *
3: +   * Time taken = distance / max_velocity
3: +   * Example: 2 meters at 0.2 m/s = 10 seconds
3: +   */
3: +
3: +  // Get current position and heading
3: +  geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();
3: +  float current_yaw = getHeading(current_pose.pose.orientation);
3: +
3: +  RCLCPP_INFO(node->get_logger(), "=== Velocity Control Movement ===");
3: +  RCLCPP_INFO(node->get_logger(), "Current heading: %.2f degrees", current_yaw * 180.0 / M_PI);
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Body frame: forward=%.2f m, left=%.2f m, up=%.2f m", forward_x, left_y,
3: +    up_z);
3: +  RCLCPP_INFO(node->get_logger(), "Max velocity: %.2f m/s", max_velocity);
3: +
3: +  // Transform body-frame movement to global frame using current heading
3: +  float global_x = forward_x * cos(current_yaw) - left_y * sin(current_yaw);
3: +  float global_y = forward_x * sin(current_yaw) + left_y * cos(current_yaw);
3: +
3: +  // Calculate target position in global frame (using relative altitude)
3: +  float target_x = current_pose.pose.position.x + global_x;
3: +  float target_y = current_pose.pose.position.y + global_y;
3: +  float current_relative_z = node->getRelativeAltitude();
3: +  float target_z = current_relative_z + up_z;
3: +
3: +  // print log every 0.2 seconds
3: +  RCLCPP_INFO_THROTTLE(
3: +    node->get_logger(),
3: +    *node->get_clock(), 200, "Target global: x=%.2f, y=%.2f, z=%.2f", target_x, target_y, target_z);
3: +
3: +  // Calculate total distance to travel
3: +  float total_distance = sqrt(global_x * global_x + global_y * global_y + up_z * up_z);
3: +  float estimated_time = total_distance / max_velocity;
3: +
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Total distance: %.2f m, Estimated time: %.1f seconds",
3: +    total_distance, estimated_time);
3: +
3: +  // PX4 OFFBOARD: Use fast rate for continuous streaming
3: +  rclcpp::Rate fast_rate(20.0);   // 20Hz
3: +
3: +  // Main control loop
3: +  while (rclcpp::ok()) {
3: +    current_pose = node->getCurrentLocalPose();
3: +
3: +    // Calculate current distance to target (using relative altitude for Z)
3: +    float dx = target_x - current_pose.pose.position.x;
3: +    float dy = target_y - current_pose.pose.position.y;
3: +    float current_relative_z_loop = node->getRelativeAltitude();
3: +    float dz = target_z - current_relative_z_loop;
3: +    float current_distance = sqrt(dx * dx + dy * dy + dz * dz);
3: +
3: +    // Check if we've reached the target
3: +    if (current_distance < tolerance) {
3: +      RCLCPP_INFO(node->get_logger(), "Target reached! Distance: %.3f m", current_distance);
3: +      break;
3: +    }
3: +
3: +    // Calculate velocity direction (unit vector towards target)
3: +    geometry_msgs::msg::TwistStamped vel_cmd;
3: +    vel_cmd.header.stamp = node->now();
3: +    vel_cmd.header.frame_id = "map";
3: +
3: +    // Normalize direction and multiply by max_velocity
3: +    vel_cmd.twist.linear.x = (dx / current_distance) * max_velocity;
3: +    vel_cmd.twist.linear.y = (dy / current_distance) * max_velocity;
3: +
3: +    // Add deadband for Z to prevent altitude drift
3: +    if (std::abs(dz) > 0.15f) {      // Only control altitude if error > 15cm
3: +      vel_cmd.twist.linear.z = (dz / current_distance) * max_velocity;
3: +    } else {
3: +      vel_cmd.twist.linear.z = 0.0;        // Hold altitude when close enough
3: +    }
3: +
3: +    // Publish velocity command
3: +    node->publishLocalVelocity(vel_cmd);
3: +
3: +    // Log progress (throttled to 1 Hz)
3: +    RCLCPP_INFO_THROTTLE(
3: +      node->get_logger(), *node->get_clock(), 1000,
3: +      "Distance remaining: %.3f m | Velocity: vx=%.2f, vy=%.2f, vz=%.2f",
3: +      current_distance,
3: +      vel_cmd.twist.linear.x,
3: +      vel_cmd.twist.linear.y,
