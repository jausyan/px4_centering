3: +void centeringBunder(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float speed_xy, bool & status,
3: +  float acc, float maxAccel, float min_center_time)
3: +{
3: +  /**
3: +   * Center the ember by adjusting the drone's position based on the ember's current position.
3: +   * The drone will adjust its velocity to center the ember while maintaining a stable hover.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   * - speed_xy: float value representing the speed at which the drone should move in the XY plane.
3: +   * - acc: tolerance value for determining if the ember is centered.
3: +   * - maxAccel: float value representing the maximum acceleration allowed during centering.
3: +   * - dropAlt: float value representing the altitude to descend to take the ember.
3: +   *
3: +   * returns:
3: +   * - posee: reference to where the last drone position when this function is called, it will be modified to the last drone position when this function returns.
3: +   * - status: reference to a boolean indicating whether centering is successful or not. Modified by the function (true if successful, false otherwise)
3: +   */
3: +
3: +  RCLCPP_INFO(node->get_logger(), "------------- Starting to Center Bunder --------------");
3: +  status = false;
3: +  rclcpp::Time start_time = node->now();
3: +  rclcpp::Time last_detected_time = node->now();   // Waktu terakhir Bunder terdeteksi
3: +  const float dropAlt = 0.85;
3: +
3: +  // const float speed_xy = 0.4;
3: +  float roll, pitch; bool detected = false;
3: +  geometry_msgs::msg::PoseStamped avg_bunder_pose; int avg_sample = 1; int buffer_size = 4;
3: +  std::vector<geometry_msgs::msg::PoseStamped> cache;
3: +  geometry_msgs::msg::PoseStamped last_last_bunder_pose = posee;
3: +  geometry_msgs::msg::TwistStamped lastVel, velocity_msg;
3: +  geometry_msgs::msg::Point error, err_i, speed_local, bunder_offset;
3: +  lastVel = node->getCurrentVelocity();
3: +
3: +  err_i.x = 0;
3: +  err_i.y = 0;
3: +  float speed_i = 0.0;
3: +
3: +  bunder_offset.x = -limit(node->getLastBunderPose().pose.position.x, 0.1);
3: +  bunder_offset.y = -limit(node->getLastBunderPose().pose.position.y, 0.1);
3: +
3: +  rclcpp::Time last_center_time = rclcpp::Time(0, 0);
3: +  bool centered = false;
3: +
3: +  if (!bunderDetected(node)) {
3: +    if (node->getLastNonZeroPoseBunder().pose.position.x != 0.0 &&
3: +      node->getLastNonZeroPoseBunder().pose.position.y != 0.0 &&
3: +      node->getLastNonZeroPoseBunder().pose.position.z != 0.0)
3: +    {
3: +      RCLCPP_INFO(
3: +        node->get_logger(),
3: +        "Tadi sempet detect tapi sekarang ngilang, coba ke pose deteksi terakhir ya...");
3: +
3: +      // Get current pose
3: +      geometry_msgs::msg::PoseStamped last_drone_nonzero_pose = node->getDroneNonZeroPoseBunder();
3: +
3: +      // Get current bunder pose in local frame
