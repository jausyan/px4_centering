3: +void land(const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate)
3: +{
3: +  /**
3: +   * Initiate the landing procedure for the drone by sending a land command.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   */
3: +  auto land_req = std::make_shared<mavros_msgs::srv::CommandTOL::Request>();
3: +  land_req->altitude = 0;
3: +  if (node->isLandServiceReady()) {
3: +    auto result = node->land_(land_req);
3: +    if (hasReplied(node, result)) {
3: +      RCLCPP_INFO(node->get_logger(), "land command sent"); waitLand(node, rate);
3: +    } else {RCLCPP_ERROR(node->get_logger(), "failed to send land command");}
3: +  }
3: +}
3: +
3: +void safeLanding(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float descent_rate = 0.3)
3: +{
3: +  /**
3: +   * Perform controlled safe landing with gradual descent in OFFBOARD mode.
3: +   * Much safer than using LAND mode which can be too fast.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   * - posee: reference to current pose (will be updated during descent)
3: +   * - descent_rate: descent speed in m/s (default 0.3 m/s = gentle descent)
3: +   */
3: +  RCLCPP_INFO(node->get_logger(), "=== Starting Safe Landing ===");
3: +  RCLCPP_INFO(node->get_logger(), "Descent rate: %.2f m/s", descent_rate);
3: +
3: +  rclcpp::Rate fast_rate(20.0);   // 20Hz for smooth control
3: +
3: +  // Get current position
3: +  geometry_msgs::msg::PoseStamped current_pose = node->getCurrentLocalPose();
3: +  geometry_msgs::msg::PoseStamped target_pose = current_pose;
3: +
3: +  float initial_altitude = current_pose.pose.position.z;
3: +  float target_ground_altitude = 0.05f;   // Stop just above ground (5cm)
3: +
3: +  RCLCPP_INFO(node->get_logger(), "Current altitude: %.2f m", initial_altitude);
3: +
3: +  // Phase 1: Controlled descent to near ground
3: +  auto descent_start = node->now();
3: +
3: +  while (rclcpp::ok()) {
3: +    current_pose = node->getCurrentLocalPose();
3: +    float current_alt = current_pose.pose.position.z;
3: +
3: +    // Check if near ground
3: +    if (current_alt <= target_ground_altitude) {
3: +      RCLCPP_INFO(node->get_logger(), "Near ground (%.2f m), proceeding to disarm...", current_alt);
3: +      break;
3: +    }
3: +
3: +    // Calculate time-based descent
3: +    float elapsed = (node->now() - descent_start).seconds();
3: +    float desired_alt = initial_altitude - (descent_rate * elapsed);
3: +
3: +    // Don't go below ground
3: +    if (desired_alt < target_ground_altitude) {
3: +      desired_alt = target_ground_altitude;
3: +    }
3: +
3: +    // Set target position (maintain x,y, only decrease z)
3: +    target_pose.pose.position.x = current_pose.pose.position.x;
3: +    target_pose.pose.position.y = current_pose.pose.position.y;
3: +    target_pose.pose.position.z = desired_alt;
3: +    target_pose.pose.orientation = current_pose.pose.orientation;
3: +
3: +    // Stream setpoint
3: +    target_pose.header.stamp = node->now();
3: +    target_pose.header.frame_id = "map";
3: +    node->publishLocalPosition(target_pose);
3: +
3: +    // Log progress
3: +    if (fmod(elapsed, 1.0) < 0.05) {     // Every ~1 second
3: +      RCLCPP_INFO(
3: +        node->get_logger(), "Landing... Alt: %.2f m -- %.2f m",
3: +        current_alt, desired_alt);
3: +    }
3: +
3: +    rclcpp::spin_some(node);
3: +    fast_rate.sleep();
3: +  }
3: +
3: +  // Phase 2: Hold position briefly at ground level
3: +  RCLCPP_INFO(node->get_logger(), "Holding at ground level for 0.5s...");
3: +  target_pose = node->getCurrentLocalPose();
3: +  target_pose.pose.position.z = 0.0;   // Target ground
3: +
3: +  auto hold_start = node->now();
3: +  while ((node->now() - hold_start).seconds() < 0.5 && rclcpp::ok()) {
3: +    target_pose.header.stamp = node->now();
3: +    node->publishLocalPosition(target_pose);
3: +    rclcpp::spin_some(node);
3: +    fast_rate.sleep();
3: +  }
3: +
3: +  // // Phase 3: Disarm (safe on ground)
3: +  // RCLCPP_INFO(node->get_logger(), "Disarming...");
3: +  // auto arm_request = std::make_shared<mavros_msgs::srv::CommandBool::Request>();
3: +  // arm_request->value = false; // Disarm
3: +
3: +  // if (node->isArmingServiceReady()) {
3: +  //     auto result = node->arm_(arm_request);
3: +  //     if (hasReplied(node, result)) {
3: +  //         auto response = result.get();
3: +  //         if (response->success) {
3: +  //             RCLCPP_INFO(node->get_logger(), "Disarmed successfully");
3: +  //         } else {
3: +  //             RCLCPP_WARN(node->get_logger(), "Disarm command sent but not confirmed");
3: +  //         }
3: +  //     }
3: +  // }
3: +
3: +  // Continue streaming at ground for safety
3: +  for (int i = 0; i < 20; i++) {   // 1 second
3: +    target_pose.header.stamp = node->now();
3: +    node->publishLocalPosition(target_pose);
3: +    rclcpp::spin_some(node);
3: +    fast_rate.sleep();
3: +  }
3: +
3: +  RCLCPP_INFO(node->get_logger(), "Safe landing complete!");
3: +  posee = node->getCurrentLocalPose();
3: +}
3: +
3: +void Descend(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee)
3: +{
3: +  /**
3: +   * Descend the drone to a lower altitude while checking if the payload is detected. Used to take the payload on the ground.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   *
3: +   * returns:
3: +   * - posee: reference to where the last drone position when this function is called, it will be modified to the last drone position when this function returns.
3: +   */
3: +  RCLCPP_INFO(node->get_logger(), "===================== Turun ===================");
3: +  geometry_msgs::msg::TwistStamped vel;
3: +  bool was_descending = false, trying_descending = false;
3: +
3: +  vel.twist.linear.x = 0.0;
3: +  vel.twist.linear.y = 0.0;
3: +  vel.twist.linear.z = -0.6;
3: +
3: +  while (rclcpp::ok()) {
3: +    node->publishLocalVelocity(vel);
3: +    if (node->getCurrentVelocity().twist.linear.z < -0.05 && !trying_descending) {
3: +      RCLCPP_INFO(node->get_logger(), "Descend started");trying_descending = true;
3: +    }
3: +    if (node->getCurrentVelocity().twist.linear.z < -0.35) {
3: +      RCLCPP_INFO(node->get_logger(), "Descending...");was_descending = true;
3: +    }
3: +    if (was_descending && payloadDetected(node)) {
3: +      node->setLastPayloadPose(node->getCurrentPosePayload());
3: +    }
3: +    if (abs(node->getCurrentVelocity().twist.linear.z) < 0.055 && was_descending) {
3: +      RCLCPP_INFO(node->get_logger(), "Landed");break;
3: +    }
3: +    rclcpp::spin_some(node);rate.sleep();
3: +  }
3: +
3: +  RCLCPP_INFO(
3: +    node->get_logger(), "Latest offset: %f, %f",
3: +    node->getLastPayloadPose().pose.position.x, node->getLastPayloadPose().pose.position.y);
3: +  posee = node->getCurrentLocalPose();
3: +}
3: +
3: +void calibrateHoverOrientation(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float max_time,
3: +  float hover_pitch, float hover_roll, bool calibrate_pitch,
3: +  bool calibrate_roll)
3: +{
3: +  RCLCPP_INFO(node->get_logger(), "------------- Calibrate Hover Orientation --------------");
3: +  stabilize(node, rate, posee, max_time);
3: +
3: +  posee = node->getCurrentLocalPose();
3: +  hover_pitch = calibrate_pitch ? getPitch(posee.pose.orientation) : hover_pitch;
3: +  hover_roll = calibrate_roll ? getRoll(posee.pose.orientation) : hover_roll;
3: +
3: +  RCLCPP_INFO(node->get_logger(), "hover_pitch = %f, hover_roll = %f", hover_pitch, hover_roll);
3: +}
3: +
3: +void centeringPayload(
3: +  const std::shared_ptr<DroneController> & node, rclcpp::Rate & rate,
3: +  geometry_msgs::msg::PoseStamped & posee, float speed_xy, bool & status,
3: +  float acc, float maxAccel, float x, float y, float min_center_time,
3: +  float max_center_pitch, float max_center_roll, float hover_pitch,
3: +  float hover_roll, std::string recovery_method,
3: +  std::string centering_setpoint_mode)
3: +{
3: +  /**
3: +   * Center the payload by adjusting the drone's position based on the payload's current position.
3: +   * The drone will adjust its velocity to center the payload while maintaining a stable hover.
3: +   *
3: +   * parameters:
3: +   * - node: shared pointer to the DroneController node instance.
3: +   * - rate: reference to the rclcpp::Rate object for controlling the loop rate.
3: +   * - speed_xy: float value representing the speed at which the drone should move in the XY plane.
3: +   * - acc: tolerance value for determining if the payload is centered.
3: +   * - maxAccel: float value representing the maximum acceleration allowed during centering.
3: +   * - dropAlt: float value representing the altitude to descend to take the payload.
3: +   *
3: +   * returns:
3: +   * - posee: reference to where the last drone position when this function is called, it will be modified to the last drone position when this function returns.
3: +   * - status: reference to a boolean indicating whether centering is successful or not. Modified by the function (true if successful, false otherwise)
3: +   */
3: +
3: +  RCLCPP_INFO(node->get_logger(), "------------- Starting to Center Payload --------------");
